{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@server/*": ["src/server/*"],
      "@styles/*": ["src/styles/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*", "scripts/**/*", "astro.config.mjs"]
}
