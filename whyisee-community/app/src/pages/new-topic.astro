---
import AdminTopicForm from "@components/AdminTopicForm.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro } from "@lib/auth";
import { getLangFromAstro } from "@lib/i18n";
import type { TopicType } from "@lib/types";
import { listCategories, listTags } from "@server/services/categories";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);

if (!session) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`, 303);
}

const categories = await listCategories(lang);
const tags = await listTags(lang);
const error = Astro.url.searchParams.get("error") === "1";
const requestedCategorySlug = Astro.url.searchParams.get("category") || "";
const requestedTagSlug = Astro.url.searchParams.get("tag") || "";
const requestedType = readTopicType(Astro.url.searchParams.get("type"));
const defaultCategorySlug = categories.some((category) => category.slug === requestedCategorySlug)
  ? requestedCategorySlug
  : undefined;
const defaultTagSlugs = tags.some((tag) => tag.slug === requestedTagSlug) ? [requestedTagSlug] : [];
const copy = lang === "en"
  ? {
      title: "New topic",
      description: "Submit a topic for review. It will be visible after approval.",
      submit: "Submit",
    }
  : {
      title: "新建话题",
      description: "提交话题后进入审核，通过后公开展示。",
      submit: "提交",
    };

function readTopicType(value: string | null): TopicType | undefined {
  return value === "discussion" ||
    value === "question" ||
    value === "article" ||
    value === "project" ||
    value === "resource"
    ? value
    : undefined;
}
---

<BaseLayout title={`${copy.title} - whyisee.xyz`} description={copy.description}>
  <section class="article-page new-topic-page">
    <AdminTopicForm
      action="/api/topics"
      categories={categories}
      tags={tags}
      lang={lang}
      error={error}
      submitLabel={copy.submit}
      cancelHref="/latest"
      showAdminFields={false}
      forcedStatus="pending"
      defaultCategorySlug={defaultCategorySlug}
      defaultTagSlugs={defaultTagSlugs}
      defaultType={requestedType}
    />
  </section>
</BaseLayout>
