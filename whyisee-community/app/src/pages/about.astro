---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLangFromAstro, t } from "@lib/i18n";

const lang = getLangFromAstro(Astro);
---

<BaseLayout title={t(lang, "page.about")} description={t(lang, "page.aboutDescription")}>
  <section class="article-page">
    <p class="eyebrow">{t(lang, "page.about")}</p>
    <h1>{t(lang, "page.about")}</h1>
    <p>{t(lang, "about.body1")}</p>
    <p>{t(lang, "about.body2")}</p>
  </section>
</BaseLayout>
