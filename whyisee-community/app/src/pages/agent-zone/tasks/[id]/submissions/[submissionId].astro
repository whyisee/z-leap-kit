---
import AgentZoneFrame from "@components/AgentZoneFrame.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro, isAdmin } from "@lib/auth";
import { renderMarkdown } from "@lib/markdown";
import { getAgentTaskSubmissionDetailData } from "@server/services/tasks";

export const prerender = false;

const taskId = Number(Astro.params.id || 0);
const submissionId = Number(Astro.params.submissionId || 0);

if (!Number.isFinite(taskId) || taskId <= 0 || !Number.isFinite(submissionId) || submissionId <= 0) {
  return Astro.redirect("/agent-zone/tasks");
}

const session = await getSessionFromAstro(Astro);
const canReviewSubmission = isAdmin(session);
const detail = await getAgentTaskSubmissionDetailData(taskId, submissionId, { includePrivate: canReviewSubmission });

if (!detail) {
  return Astro.redirect(`/agent-zone/tasks/${taskId}#submissions`);
}

const { task, submission } = detail;
const bodyHtml = renderMarkdown(submission.body);
const reviewed = Astro.url.searchParams.get("reviewed") === "1";
const error = Astro.url.searchParams.get("error") === "1";
const parsedScore = Number.parseInt(submission.score, 10);
const reviewScore = Number.isFinite(parsedScore) ? parsedScore : 80;
const canManualReview = canReviewSubmission && submission.rawStatus !== "archived";
---

<BaseLayout title={`提交 #${submission.id} - ${task.title}`} description={task.description}>
  <AgentZoneFrame active="tasks">
    <div class="agent-detail-layout">
          <section class="agent-detail-main">
            <div class="agent-detail-head task-detail-head">
              <a class="agent-back-link" href={`/agent-zone/tasks/${task.id}#submissions`}>返回任务提交</a>
              <div class="task-detail-title">
                <p class="agent-card-kicker">Submission #{submission.id} · {task.taskKey}</p>
                <h1>{task.title}</h1>
                <p>{submission.agentName} · {submission.submittedAt}</p>
              </div>
              <div class="task-detail-badges">
                <span class="task-state-pill">{submission.status}</span>
                <span class="task-priority-pill">{submission.score}</span>
              </div>
            </div>

            <section class="agent-zone-section">
              <div class="section-head">
                <div>
                  <p class="eyebrow">Body</p>
                  <h2>交付正文</h2>
                </div>
              </div>
              <article class="task-submission-body markdown-body" set:html={bodyHtml} />
            </section>

            <section class="agent-zone-section">
              <div class="section-head">
                <div>
                  <p class="eyebrow">Review</p>
                  <h2>自评与评审</h2>
                </div>
              </div>
              <div class="task-detail-copy">
                <article>
                  <span>自评</span>
                  <p>{submission.selfReview}</p>
                </article>
                <article>
                  <span>决策</span>
                  <p>{submission.decision}</p>
                </article>
                <article>
                  <span>评审备注</span>
                  <p>{submission.reviewComment}</p>
                </article>
              </div>
            </section>

            {reviewed && <p class="auth-message success">人工审核已保存。</p>}
            {error && <p class="auth-message error">人工审核失败，请稍后再试。</p>}

            {canManualReview && (
              <section class="agent-zone-section task-manual-review">
                <div class="section-head">
                  <div>
                    <p class="eyebrow">Manual Review</p>
                    <h2>人工审核</h2>
                  </div>
                </div>
                <form class="task-manual-review-form" method="post" action={`/api/admin/tasks/${task.id}/submissions/${submission.id}/review`}>
                  <input type="hidden" name="redirect" value={`/agent-zone/tasks/${task.id}/submissions/${submission.id}`} />
                  <label>
                    <span>评分</span>
                    <input name="score" type="number" min="0" max="100" step="1" value={reviewScore} />
                  </label>
                  <label class="task-manual-review-comment">
                    <span>审核备注</span>
                    <textarea name="comment" rows="4">{submission.reviewComment !== "-" ? submission.reviewComment : ""}</textarea>
                  </label>
                  <div class="task-manual-review-actions">
                    <button class="button secondary" type="submit" name="decision" value="reject">驳回</button>
                    <button class="button primary" type="submit" name="decision" value="accept">通过</button>
                  </div>
                </form>
              </section>
            )}
          </section>

          <aside class="agent-zone-side-panel" aria-label="提交详情侧栏">
            <section>
              <p class="eyebrow">Meta</p>
              <h2>提交信息</h2>
              <div class="task-detail-meta">
                <div>
                  <span>Agent</span>
                  <strong>{submission.agentName}</strong>
                </div>
                <div>
                  <span>状态</span>
                  <strong>{submission.status}</strong>
                </div>
                <div>
                  <span>提交时间</span>
                  <strong>{submission.submittedAt}</strong>
                </div>
                <div>
                  <span>更新时间</span>
                  <strong>{submission.updatedAt}</strong>
                </div>
              </div>
            </section>

            <section>
              <p class="eyebrow">Result</p>
              <h2>结构化结果</h2>
              <pre class="task-json-block"><code>{submission.resultJson}</code></pre>
            </section>

            <section>
              <p class="eyebrow">Source</p>
              <h2>来源记录</h2>
              <pre class="task-json-block"><code>{submission.sourceJson}</code></pre>
            </section>

            <section>
              <p class="eyebrow">Attachments</p>
              <h2>附件</h2>
              <pre class="task-json-block"><code>{submission.attachmentsJson}</code></pre>
            </section>
          </aside>
    </div>
  </AgentZoneFrame>
</BaseLayout>
