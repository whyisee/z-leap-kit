---
import AgentZoneFrame from "@components/AgentZoneFrame.astro";
import AgentTaskForm from "@components/AgentTaskForm.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro, isAdmin } from "@lib/auth";
import { getAdminTaskEditData } from "@server/services/tasks";

export const prerender = false;

const session = await getSessionFromAstro(Astro);

if (!session) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(Astro.url.pathname)}`, 303);
}

if (!isAdmin(session)) {
  return Astro.redirect("/agent-zone/tasks", 303);
}

const taskId = Number(Astro.params.id || 0);

if (!Number.isFinite(taskId) || taskId <= 0) {
  return Astro.redirect("/agent-zone/tasks");
}

const task = await getAdminTaskEditData(taskId);

if (!task) {
  return Astro.redirect("/agent-zone/tasks");
}

const error = Astro.url.searchParams.get("error") === "1";
const saved = Astro.url.searchParams.get("saved") === "1";
const formId = `agent-task-edit-form-${task.id}`;
---

<BaseLayout title={`修改任务 #${task.id} - Agent 专区`} description={task.description}>
  <AgentZoneFrame active="tasks">
    <section class="agent-zone-section agent-task-create-page">
          <div class="agent-task-create-toolbar">
            <a class="agent-back-link" href={`/agent-zone/tasks/${task.id}`}>返回任务详情</a>
            <div class="agent-task-submit-actions">
              <button
                class:list={["button", task.status === "draft" ? "secondary" : "primary"]}
                type="submit"
                form={formId}
                name="status"
                value={task.status}
              >
                保存修改
              </button>
              {task.status === "draft" && (
                <button class="button primary" type="submit" form={formId} name="status" value="open">提交</button>
              )}
            </div>
          </div>

          {error && <p class="auth-message error">保存失败，请检查必填字段和高级配置 JSON。</p>}
          {saved && <p class="auth-message success">任务已保存。</p>}

          <AgentTaskForm
            formId={formId}
            action={`/api/admin/tasks/${task.id}`}
            redirect={`/agent-zone/tasks/${task.id}`}
            errorRedirect={`/agent-zone/tasks/${task.id}/edit`}
            task={task}
          />
    </section>
  </AgentZoneFrame>
</BaseLayout>
