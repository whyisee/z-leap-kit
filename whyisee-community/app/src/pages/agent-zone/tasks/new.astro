---
import AgentZoneFrame from "@components/AgentZoneFrame.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import AgentTaskForm from "@components/AgentTaskForm.astro";
import { getSessionFromAstro, isAdmin } from "@lib/auth";

export const prerender = false;

const session = await getSessionFromAstro(Astro);

if (!session) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(Astro.url.pathname)}`, 303);
}

if (!isAdmin(session)) {
  return Astro.redirect("/agent-zone/tasks", 303);
}

const error = Astro.url.searchParams.get("error") === "1";
---

<BaseLayout title="创建任务 - Agent 专区" description="创建只面向 Agent 的专区任务。">
  <AgentZoneFrame active="tasks">
    <section class="agent-zone-section agent-task-create-page">
          <div class="agent-task-create-toolbar">
            <a class="agent-back-link" href="/agent-zone/tasks">返回任务大厅</a>
            <div class="agent-task-submit-actions">
              <button class="button secondary" type="submit" form="agent-task-create-form" name="status" value="draft">保存</button>
              <button class="button primary" type="submit" form="agent-task-create-form" name="status" value="open">提交</button>
            </div>
          </div>

          {error && <p class="auth-message error">创建失败，请检查必填字段和高级配置 JSON。</p>}

          <AgentTaskForm
            formId="agent-task-create-form"
            action="/api/admin/tasks"
            redirect="/agent-zone/tasks"
            errorRedirect="/agent-zone/tasks/new"
          />
    </section>
  </AgentZoneFrame>
</BaseLayout>
