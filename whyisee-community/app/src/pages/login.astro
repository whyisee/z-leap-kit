---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro, safeRedirectPath } from "@lib/auth";
import { getLangFromAstro, t } from "@lib/i18n";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);
const redirectTarget = safeRedirectPath(Astro.url.searchParams.get("redirect"), "/");
const hasError = Astro.url.searchParams.get("error") === "1";
const signedUp = Astro.url.searchParams.get("signedUp") === "1";
const reset = Astro.url.searchParams.get("reset") === "1";

if (session) {
  return Astro.redirect(redirectTarget, 303);
}
---

<BaseLayout title={`${t(lang, "auth.loginTitle")} - whyisee.xyz`} description={t(lang, "auth.loginDescription")}>
  <section class="article-page auth-page">
    <div class="auth-card">
      <p class="eyebrow">{t(lang, "auth.loginAction")}</p>
      <h1>{t(lang, "auth.loginTitle")}</h1>
      <p>{t(lang, "auth.loginDescription")}</p>

      {hasError && <p class="auth-message error">{t(lang, "auth.loginError")}</p>}
      {signedUp && <p class="auth-message muted">{lang === "en" ? "Account created. You can sign in now." : "账号已创建，现在可以登录。"}</p>}
      {reset && <p class="auth-message muted">{lang === "en" ? "Password updated. You can sign in now." : "密码已更新，现在可以登录。"}</p>}

      <form class="auth-form" method="post" action="/api/login">
        <input type="hidden" name="redirect" value={redirectTarget} />
        <label>
          {t(lang, "auth.username")}
          <input
            autocomplete="username"
            name="username"
            placeholder={t(lang, "auth.usernamePlaceholder")}
            required
            type="text"
          />
        </label>
        <label>
          {t(lang, "auth.password")}
          <input
            autocomplete="current-password"
            name="password"
            placeholder={t(lang, "auth.passwordPlaceholder")}
            required
            type="password"
          />
        </label>
        <button class="button primary" type="submit">{t(lang, "auth.loginAction")}</button>
        <div class="auth-links">
          <a href="/signup">{lang === "en" ? "Create account" : "注册账号"}</a>
          <a href="/forgot-password">{lang === "en" ? "Forgot password" : "忘记密码"}</a>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
