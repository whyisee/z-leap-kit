---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getTopicById } from "@server/services/topics";

export const prerender = false;

const id = Number(Astro.params.id || 0);
const topic = Number.isFinite(id) && id > 0 ? await getTopicById(id) : undefined;

if (topic) {
  return Astro.redirect(`/t/${topic.id}${Astro.url.search}`, 301);
}

Astro.response.status = 404;
---

<BaseLayout title="Topic not found - whyisee.xyz">
  <section class="article-page">
    <h1>Topic not found</h1>
  </section>
</BaseLayout>
