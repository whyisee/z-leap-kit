---
import BaseLayout from "@layouts/BaseLayout.astro";
import LeftNav from "@components/LeftNav.astro";
import MarkdownContent from "@components/MarkdownContent.astro";
import TopicAiController from "@components/TopicAiController.astro";
import TopicReplyController from "@components/TopicReplyController.astro";
import TopicReplySection from "@components/TopicReplySection.astro";
import UserHoverPopover from "@components/UserHoverPopover.astro";
import { getAnonymousInitial } from "@lib/anonymous";
import { getSessionFromAstro } from "@lib/auth";
import { categoryPath, tagPath, topicPath } from "@lib/routes";
import { formatRelative } from "@lib/format";
import { getLangFromAstro, t } from "@lib/i18n";
import { enhanceMarkdownHtml } from "@lib/markdown";
import { buildTopicJsonLd } from "@lib/seo";
import { listCategories, listTags } from "@server/services/categories";
import { countTargetLikes, getTopicInteractionState, getUserFollowStats, userFollowsTarget, userLikedTarget } from "@server/services/interactions";
import { listPostsForTopic } from "@server/services/posts";
import { listReadingRecommendations } from "@server/services/recommendations";
import { getTopicById } from "@server/services/topics";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);
const id = Number(Astro.params.id || 0);
const topic = await getTopicById(id, lang);

const siteBase = Astro.site?.toString() || process.env.SITE_URL || "https://whyisee.xyz";
const topicUrl = topic
  ? new URL(lang === "en" ? `${topicPath(topic)}?lang=en` : topicPath(topic), siteBase).toString()
  : `${Astro.url.origin}${Astro.url.pathname}`;
const topicImageUrl = new URL("/og-image.png", siteBase).toString();
const seoLang = lang === "en" ? "en" : "zh-CN";

if (!topic) {
  Astro.response.status = 404;
}

const readingRecommendations = topic
  ? await listReadingRecommendations({ topic, userId: session?.userId, lang, limit: 12 })
  : [];
const nextTopic = readingRecommendations[0]?.topic;
const nextTopicUrls = readingRecommendations.map((item) => item.href);
const readingRecommendationItems = readingRecommendations.map((item) => ({
  targetType: item.targetType,
  targetId: item.targetId,
  href: item.href,
  score: item.score,
  reasons: item.reasons,
}));
const posts = topic ? await listPostsForTopic(topic.id, session?.userId, lang) : [];
const topicInteraction = topic ? await getTopicInteractionState(topic.id, session?.userId) : undefined;
const postInteractionEntries = await Promise.all(
  posts.map(async (post) => [
    post.id,
    {
      likeCount: await countTargetLikes("post", post.id),
      liked: await userLikedTarget("post", post.id, session?.userId),
    },
  ] as const),
);
const postInteractions = new Map(postInteractionEntries);
const avatarInitial = (value: string | undefined, fallback = "W") => {
  const initial = value?.trim().slice(0, 1);
  return initial ? initial.toUpperCase() : fallback;
};
const currentUserInitial = avatarInitial(session?.displayName || session?.username);
const isAnonymousTopic = Boolean(topic?.author.isAnonymous);
const anonymousInitial = getAnonymousInitial(lang);
const topicAuthorInitial = isAnonymousTopic ? anonymousInitial : avatarInitial(topic?.author.displayName || topic?.author.username);
const topicAuthorFollowed = topic && !isAnonymousTopic
  ? await userFollowsTarget("user", topic.author.id, session?.userId)
  : false;
const showTopicAuthorFollowButton = Boolean(topic && !isAnonymousTopic && session?.userId !== topic.author.id && !topicAuthorFollowed);
const showTopicAuthorFollowedState = Boolean(topic && !isAnonymousTopic && session?.userId !== topic.author.id && topicAuthorFollowed);
const showTopicAuthorFollowControl = Boolean(topic && !isAnonymousTopic && session?.userId !== topic.author.id);
const topicAuthorFollowStats = topic && !isAnonymousTopic
  ? await getUserFollowStats(topic.author.id)
  : { followingCount: 0, followerCount: 0 };
const allReplyItems = posts.map((post) => {
  const interaction = postInteractions.get(post.id);
  const createdAtMs = Date.parse(post.createdAt);

  return {
    post,
    authorInitial: post.author.isAnonymous ? anonymousInitial : avatarInitial(post.author.displayName || post.author.username),
    contentHtml: enhanceMarkdownHtml(post.contentHtml),
    likeCount: interaction?.likeCount ?? 0,
    liked: interaction?.liked ?? false,
    createdAtMs: Number.isNaN(createdAtMs) ? 0 : createdAtMs,
  };
});
type ReplyItem = (typeof allReplyItems)[number];
const postIds = new Set(posts.map((post) => post.id));
const childRepliesByParentId = new Map<number, ReplyItem[]>();
const replyItems: ReplyItem[] = [];

for (const item of allReplyItems) {
  const parentPostId = item.post.parentPostId;

  if (parentPostId && postIds.has(parentPostId)) {
    const children = childRepliesByParentId.get(parentPostId) || [];
    children.push(item);
    childRepliesByParentId.set(parentPostId, children);
  } else if (!parentPostId) {
    replyItems.push(item);
  }
}

replyItems.sort((a, b) => b.likeCount - a.likeCount || b.createdAtMs - a.createdAtMs || b.post.id - a.post.id);
childRepliesByParentId.forEach((children) => {
  children.sort((a, b) => b.likeCount - a.likeCount || b.createdAtMs - a.createdAtMs || b.post.id - a.post.id);
});
const categories = await listCategories(lang);
const tags = await listTags(lang);
const replyError = Astro.url.searchParams.get("replyError") === "1";
const copy = lang === "en"
  ? {
      comments: "Comments",
      replies: "Replies",
      reply: "Reply",
      replyPlaceholder: "Add a thoughtful comment...",
      submitReply: "Post reply",
      loginToReply: "Log in to reply",
      noReplies: "No replies yet. Start the conversation.",
      replyError: "Reply failed. Please check the content and try again.",
      sortHot: "Hot",
      sortLatest: "Latest",
      uploadImage: "Upload image",
      mentionUser: "Mention user or bot",
      emoji: "Emoji",
      replyToComment: "Reply",
      cancelReply: "Cancel",
      inlineReplyPlaceholder: "Reply to this comment...",
      showNestedReplies: "View replies",
      hideNestedReplies: "Hide replies",
      moreActions: "More actions",
      copyCommentLink: "Copy comment link",
      copiedCommentLink: "Copied",
      blockUser: "Block user",
      editReply: "Edit",
      like: "Like",
      liked: "Liked",
      bookmark: "Bookmark",
      bookmarked: "Bookmarked",
      comment: "Comment",
      share: "Share",
      shareCopied: "Link copied",
      follow: "Follow",
      following: "Following",
      report: "Report",
      aiButton: "AI",
      aiMenuLabel: "AI tools",
      aiLoading: "AI is thinking...",
      aiError: "AI request failed. Please try again later.",
      aiLoginRequired: "Please log in before using AI tools.",
      aiNotConfigured: "AI model is not configured yet. Ask an admin to configure it in AI Settings.",
      aiKeyMissing: "The default AI model is missing an API key.",
      aiTimeout: "AI request timed out. Try again with a shorter topic.",
      aiCopy: "Copy",
      aiCopied: "Copied",
      aiClose: "Close",
      aiResultMeta: "Generated by",
      author: "Author",
      topicOwner: "Topic owner",
      signatureFallback: "No signature yet.",
      joined: "Joined",
      profile: "View profile",
      message: "Message",
      role: "Role",
      followingCount: "Following",
      followersCount: "Followers",
      noPreviousTopic: "Nothing above.",
      noNextTopic: "Nothing below.",
      anonymousUser: "Anonymous",
      anonymousBadge: "Tree Hole",
      anonymousBio: "Identity is hidden in this Tree Hole topic.",
    }
  : {
      comments: "评论",
      replies: "回复",
      reply: "回复",
      replyPlaceholder: "你渴望拥有力量吗？评论让力量更强大",
      submitReply: "发布",
      loginToReply: "登录后回复",
      noReplies: "还没有回复，来开个头。",
      replyError: "回复失败，请检查内容后重试。",
      sortHot: "最热",
      sortLatest: "最新",
      uploadImage: "上传图片",
      mentionUser: "@ 用户或机器人",
      emoji: "表情包",
      replyToComment: "回复",
      cancelReply: "取消",
      inlineReplyPlaceholder: "回复这条评论...",
      showNestedReplies: "查看回复",
      hideNestedReplies: "收起回复",
      moreActions: "更多操作",
      copyCommentLink: "复制评论链接",
      copiedCommentLink: "已复制",
      blockUser: "加入黑名单",
      editReply: "编辑",
      like: "点赞",
      liked: "已点赞",
      bookmark: "收藏",
      bookmarked: "已收藏",
      comment: "评论",
      share: "转发",
      shareCopied: "链接已复制",
      follow: "关注",
      following: "已关注",
      report: "举报",
      aiButton: "AI",
      aiMenuLabel: "AI 工具",
      aiLoading: "AI 正在思考...",
      aiError: "AI 请求失败，请稍后再试。",
      aiLoginRequired: "请先登录后再使用 AI 工具。",
      aiNotConfigured: "还没有配置 AI 模型，请先到 AI 配置里设置默认模型。",
      aiKeyMissing: "默认 AI 模型缺少 API Key。",
      aiTimeout: "AI 请求超时，可以换一个较短的话题再试。",
      aiCopy: "复制",
      aiCopied: "已复制",
      aiClose: "关闭",
      aiResultMeta: "生成模型",
      author: "作者",
      topicOwner: "楼主",
      signatureFallback: "还没有填写签名。",
      joined: "加入",
      profile: "查看主页",
      message: "发私信",
      role: "身份",
      followingCount: "关注",
      followersCount: "粉丝",
      noPreviousTopic: "上面没有了",
      noNextTopic: "下面没有了",
      anonymousUser: "匿名用户",
      anonymousBadge: "树洞匿名",
      anonymousBio: "树洞板块已隐藏作者和评论者身份。",
    };
const aiActions = lang === "en"
  ? [
      ["summarize", "Summarize", "Key points and context"],
      ["draft-reply", "Draft reply", "A thoughtful reply outline"],
      ["translate", "Translate", "Chinese and English reading version"],
      ["extract-actions", "Extract actions", "Tasks, risks, and next steps"],
      ["find-related", "Find related", "Similar topics and tags"],
      ["quality-check", "Quality check", "Title, category, and content review"],
    ]
  : [
      ["summarize", "总结话题", "要点、背景和结论"],
      ["draft-reply", "生成回复", "给出有信息量的回复草稿"],
      ["translate", "双语翻译", "中文和英文阅读版本"],
      ["extract-actions", "提炼行动项", "任务、风险和下一步"],
      ["find-related", "查找相关", "相似话题和标签建议"],
      ["quality-check", "质量检查", "标题、分类和内容建议"],
    ];
---

<BaseLayout
  title={`${topic?.title ?? t(lang, "topic.notFound")} - whyisee.xyz`}
  description={topic?.summary ?? t(lang, "topic.notFound")}
  ogType={topic ? "article" : "website"}
  structuredData={topic ? buildTopicJsonLd(topic, topicUrl, topicImageUrl, seoLang) : undefined}
>
  {topic ? (
    <section
      class="page-grid topic-layout no-right-sidebar"
      data-topic-reading-page
      data-topic-id={topic.id}
      data-next-topic-url={nextTopic ? topicPath(nextTopic) : ""}
      data-next-topic-title={nextTopic?.title ?? ""}
      data-next-topic-urls={JSON.stringify(nextTopicUrls)}
      data-reading-recommendations={JSON.stringify(readingRecommendationItems)}
      data-no-prev-message={copy.noPreviousTopic}
      data-no-next-message={copy.noNextTopic}
    >
      <LeftNav categories={categories} tags={tags} lang={lang} activeCategorySlug={topic.category.slug} />

      <div class="content-column">
        <article class="topic-page">
          <header class="topic-hero">
            <div class="topic-hero-bar">
              <div class="topic-title-stack">
                <h1>{topic.title}</h1>
                <div class="topic-taxonomy-row">
                  <a class="category-pill" href={categoryPath(topic.category.slug)} style={`--pill-color: ${topic.category.color}`}>
                    {topic.category.name}
                  </a>
                  {topic.tags.map((tag) => <a class="topic-tag-pill" href={tagPath(tag.slug)}>#{tag.name}</a>)}
                </div>
              </div>

            </div>
          </header>

          <section class="topic-post-frame">
            <div class:list={["topic-author-card", isAnonymousTopic && "is-anonymous"]}>
              {isAnonymousTopic ? (
                <span class="topic-author-avatar topic-author-avatar-anonymous" aria-label={copy.anonymousUser}>
                  {topicAuthorInitial}
                </span>
              ) : (
                <div class="topic-author-hover topic-author-avatar-hover">
                  <button class="topic-author-avatar-trigger" type="button" aria-haspopup="dialog" aria-label={topic.author.displayName}>
                    <span class="topic-author-avatar" aria-hidden="true">
                      {topic.author.avatarUrl
                        ? <img src={topic.author.avatarUrl} alt={`${topic.author.displayName} avatar`} loading="lazy" />
                        : topicAuthorInitial}
                    </span>
                  </button>
                  <UserHoverPopover
                    author={topic.author}
                    authorInitial={topicAuthorInitial}
                    copy={copy}
                    currentPath={Astro.url.pathname}
                    followed={topicAuthorFollowed}
                    lang={lang}
                    showFollowControl={showTopicAuthorFollowControl}
                    stats={topicAuthorFollowStats}
                  />
                </div>
              )}
            </div>

            <div class="topic-post-body">
              <div class="topic-post-head">
                <div class="topic-author-inline">
                  {isAnonymousTopic ? (
                    <span class="topic-author-name-trigger is-static">{copy.anonymousUser}</span>
                  ) : (
                    <div class="topic-author-hover">
                      <button class="topic-author-name-trigger" type="button" aria-haspopup="dialog">
                        {topic.author.displayName}
                      </button>
                      <UserHoverPopover
                        author={topic.author}
                        authorInitial={topicAuthorInitial}
                        copy={copy}
                        currentPath={Astro.url.pathname}
                        followed={topicAuthorFollowed}
                        lang={lang}
                        showFollowControl={showTopicAuthorFollowControl}
                        stats={topicAuthorFollowStats}
                      />
                    </div>
                  )}
                  <span class="topic-author-username">{isAnonymousTopic ? copy.anonymousBadge : `@${topic.author.username}`}</span>
                  <p class="topic-author-signature">{isAnonymousTopic ? copy.anonymousBio : topic.author.bio || copy.signatureFallback}</p>
                  <span class="topic-post-time">{formatRelative(topic.publishedAt, lang)}</span>
                </div>
              </div>
              <MarkdownContent html={topic.contentHtml} />
            </div>
          </section>

          <section
            class="topic-ai-result"
            data-topic-ai-result
            data-loading={copy.aiLoading}
            data-error={copy.aiError}
            data-login-required={copy.aiLoginRequired}
            data-not-configured={copy.aiNotConfigured}
            data-key-missing={copy.aiKeyMissing}
            data-timeout={copy.aiTimeout}
            data-copy={copy.aiCopy}
            data-copied={copy.aiCopied}
            data-result-meta={copy.aiResultMeta}
            hidden
          >
            <header class="topic-ai-result-head">
              <div>
                <p class="eyebrow">{copy.aiButton}</p>
                <h2 data-topic-ai-title>{copy.aiMenuLabel}</h2>
              </div>
              <div class="topic-ai-result-actions">
                <button class="action-button compact" type="button" data-topic-ai-copy>{copy.aiCopy}</button>
                <button class="action-button compact" type="button" data-topic-ai-close>{copy.aiClose}</button>
              </div>
            </header>
            <pre data-topic-ai-output></pre>
            <footer data-topic-ai-meta hidden></footer>
          </section>

          <div id="topic-replies" class="topic-replies-shell" data-topic-replies hidden={!replyError}>
            <TopicReplySection
              childRepliesByParentId={childRepliesByParentId}
              copy={copy}
              currentPath={Astro.url.pathname}
              currentUserInitial={currentUserInitial}
              lang={lang}
              postCount={posts.length}
              replyError={replyError}
              replyItems={replyItems}
              session={session}
              isAnonymousThread={isAnonymousTopic}
              topicId={topic.id}
              topicUrl={topicUrl}
            />
          </div>
        </article>
      </div>

      <nav class="topic-floating-actions" aria-label={lang === "en" ? "Topic actions" : "帖子操作"} data-topic-floating-actions>
        <div class="topic-ai-menu topic-floating-ai-menu" data-topic-ai-menu data-topic-id={topic.id}>
          <button
            class="ai-tool-button topic-floating-ai-button"
            type="button"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-label={copy.aiMenuLabel}
            data-topic-ai-button
          >
            <span class="ai-tool-mark" aria-hidden="true">AI</span>
          </button>
          <div class="topic-ai-panel" role="menu" aria-label={copy.aiMenuLabel} data-topic-ai-panel hidden>
            {aiActions.map(([id, label, description]) => (
              <button class="topic-ai-option" type="button" role="menuitem" data-ai-action={id}>
                <strong>{label}</strong>
                <span>{description}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="topic-floating-author">
          {isAnonymousTopic ? (
            <span class="topic-floating-avatar is-anonymous" aria-label={copy.anonymousUser}>{topicAuthorInitial}</span>
          ) : (
            <div class="topic-author-hover topic-floating-author-hover">
              <button class="topic-floating-avatar topic-floating-avatar-trigger" type="button" aria-haspopup="dialog" aria-label={topic.author.displayName}>
                {topic.author.avatarUrl
                  ? <img src={topic.author.avatarUrl} alt={`${topic.author.displayName} avatar`} loading="lazy" />
                  : topicAuthorInitial}
              </button>
              <UserHoverPopover
                author={topic.author}
                authorInitial={topicAuthorInitial}
                copy={copy}
                currentPath={Astro.url.pathname}
                followed={topicAuthorFollowed}
                lang={lang}
                showFollowControl={showTopicAuthorFollowControl}
                stats={topicAuthorFollowStats}
              />
            </div>
          )}

          {showTopicAuthorFollowButton && (
            <form class="topic-floating-follow-form" method="post" action="/api/interactions/follow">
              <input type="hidden" name="targetType" value="user" />
              <input type="hidden" name="targetId" value={topic.author.id} />
              <input type="hidden" name="redirect" value={Astro.url.pathname} />
              <button class="topic-floating-follow-button" type="submit" aria-label={copy.follow}>
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </button>
            </form>
          )}

          {showTopicAuthorFollowedState && (
            <span class="topic-floating-follow-state" role="img" aria-label={copy.following}>
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="m5 12 4 4 10-10" />
              </svg>
            </span>
          )}
        </div>

        <form
          class="topic-floating-action-form"
          method="post"
          action="/api/interactions/reaction"
          data-topic-interaction-form
          data-interaction-kind="like"
          data-active-label={copy.liked}
          data-inactive-label={copy.like}
        >
          <input type="hidden" name="targetType" value="topic" />
          <input type="hidden" name="targetId" value={topic.id} />
          <input type="hidden" name="redirect" value={Astro.url.pathname} />
          <button
            class:list={["topic-floating-action", topicInteraction?.liked && "is-active"]}
            type="submit"
            aria-label={`${topicInteraction?.liked ? copy.liked : copy.like} ${topicInteraction?.likeCount ?? 0}`}
            data-topic-interaction-button
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M20.4 4.8a5.1 5.1 0 0 0-7.2 0L12 6l-1.2-1.2a5.1 5.1 0 0 0-7.2 7.2L12 20.4 20.4 12a5.1 5.1 0 0 0 0-7.2Z" />
            </svg>
            <span class="topic-floating-action-count" data-topic-interaction-count>{topicInteraction?.likeCount ?? 0}</span>
          </button>
        </form>

        <form
          class="topic-floating-action-form"
          method="post"
          action="/api/interactions/bookmark"
          data-topic-interaction-form
          data-interaction-kind="bookmark"
          data-active-label={copy.bookmarked}
          data-inactive-label={copy.bookmark}
        >
          <input type="hidden" name="topicId" value={topic.id} />
          <input type="hidden" name="redirect" value={Astro.url.pathname} />
          <button
            class:list={["topic-floating-action", topicInteraction?.bookmarked && "is-active"]}
            type="submit"
            aria-label={`${topicInteraction?.bookmarked ? copy.bookmarked : copy.bookmark} ${topicInteraction?.bookmarkCount ?? 0}`}
            data-topic-interaction-button
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M6.5 4.8A2.3 2.3 0 0 1 8.8 2.5h6.4a2.3 2.3 0 0 1 2.3 2.3v16.1L12 17.5l-5.5 3.4V4.8Z" />
            </svg>
            <span class="topic-floating-action-count" data-topic-interaction-count>{topicInteraction?.bookmarkCount ?? 0}</span>
          </button>
        </form>

        <button
          class="topic-floating-action"
          type="button"
          aria-controls="topic-replies"
          aria-expanded={replyError ? "true" : "false"}
          aria-label={`${copy.comment} ${posts.length}`}
          data-topic-comment-toggle
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M21 11.5a8.5 8.5 0 0 1-11.8 7.8L4 20l1.1-5A8.5 8.5 0 1 1 21 11.5Z" />
          </svg>
          <span class="topic-floating-action-count">{posts.length}</span>
        </button>

        <button
          class="topic-floating-action"
          type="button"
          aria-label={`${copy.share} 0`}
          data-topic-share
          data-share-title={topic.title}
          data-share-url={topicUrl}
          data-share-label={copy.share}
          data-share-copied={copy.shareCopied}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M21 3 10.8 13.2" />
            <path d="m21 3-6.2 18-4-7.8L3 9.2 21 3Z" />
          </svg>
          <span class="topic-floating-action-count" data-topic-share-count>0</span>
        </button>
      </nav>
    </section>
  ) : (
    <section class="article-page">
      <h1>{t(lang, "topic.notFound")}</h1>
      <p>{t(lang, "topic.notFoundDescription")}</p>
    </section>
  )}
</BaseLayout>

<TopicAiController />
<TopicReplyController />

<script is:inline>
  (() => {
    const page = document.querySelector("[data-topic-reading-page]");

    if (!page) {
      return;
    }

    const scrollRoot = page.querySelector(".content-column");
    const hero = page.querySelector(".topic-hero");
    const postBody = page.querySelector(".topic-post-body");
    const header = document.querySelector(".site-header");
    const headerLeft = header?.querySelector(".header-left");
    const headerActions = header?.querySelector(".header-actions");
    const title = page.querySelector(".topic-title-stack h1")?.textContent?.trim() || "";
    const replies = page.querySelector("[data-topic-replies]");
    const commentToggle = page.querySelector("[data-topic-comment-toggle]");
    const floatingActions = page.querySelector("[data-topic-floating-actions]");
    const shareButton = page.querySelector("[data-topic-share]");
    const topicId = Number(page.getAttribute("data-topic-id") || 0);
    const nextTopicUrl = page.getAttribute("data-next-topic-url") || "";
    const noPreviousTopicMessage = page.getAttribute("data-no-prev-message") || "";
    const noNextTopicMessage = page.getAttribute("data-no-next-message") || "";
    const recommendationItems = (() => {
      try {
        const parsed = JSON.parse(page.getAttribute("data-reading-recommendations") || "[]");

        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    })();

    if (!scrollRoot || !hero || !postBody || !header) {
      document.documentElement.removeAttribute("data-reading-arriving");
      return;
    }

    const rememberSessionOnce = (key) => {
      try {
        if (window.sessionStorage.getItem(key)) {
          return false;
        }

        window.sessionStorage.setItem(key, "1");
      } catch {
        return true;
      }

      return true;
    };

    const trackRecommendationEvent = (payload, keepalive = false) => {
      const body = JSON.stringify(payload);

      if (keepalive && navigator.sendBeacon) {
        navigator.sendBeacon("/api/recommendations/events", new Blob([body], { type: "application/json" }));
        return;
      }

      window.fetch("/api/recommendations/events", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body,
        keepalive,
      }).catch(() => {});
    };

    if (topicId > 0 && rememberSessionOnce(`whyisee_topic_view_${topicId}`)) {
      trackRecommendationEvent({
        eventType: "view",
        targetType: "topic",
        targetId: topicId,
        sourceSurface: "reading",
      });
    }

    if (recommendationItems.length > 0) {
      const impressionKey = `whyisee_topic_reading_impressions_${topicId}_${recommendationItems.map((item) => item.targetId).join("_")}`;

      if (rememberSessionOnce(impressionKey)) {
        trackRecommendationEvent({
          surface: "reading",
          items: recommendationItems.map((item) => ({
            targetType: "topic",
            targetId: Number(item.targetId || 0),
            score: Number(item.score || 0),
            reasons: Array.isArray(item.reasons) ? item.reasons : [],
          })),
        });
      }
    }

    const pageOpenedAt = Date.now();
    let dwellSent = false;

    const sendDwellEvent = () => {
      if (dwellSent || topicId <= 0) {
        return;
      }

      const dwellSeconds = Math.round((Date.now() - pageOpenedAt) / 1000);

      if (dwellSeconds < 8) {
        return;
      }

      dwellSent = true;
      trackRecommendationEvent({
        eventType: "dwell",
        targetType: "topic",
        targetId: topicId,
        sourceSurface: "reading",
        dwellSeconds,
      }, true);
    };

    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden") {
        sendDwellEvent();
      }
    });
    window.addEventListener("pagehide", sendDwellEvent);

    let titleIndicator = header.querySelector(".reading-header-title");

    if (!titleIndicator) {
      titleIndicator = document.createElement("div");
      titleIndicator.className = "reading-header-title";
      titleIndicator.setAttribute("aria-hidden", "true");
      header.append(titleIndicator);
    }

    titleIndicator.textContent = title;

    let ticking = false;

    const getScrollTop = () => Math.max(
      scrollRoot.scrollTop || 0,
      window.scrollY || 0,
      document.documentElement.scrollTop || 0,
      document.body.scrollTop || 0,
    );

    const syncTitlePosition = () => {
      const headerRect = header.getBoundingClientRect();
      const bodyRect = postBody.getBoundingClientRect();
      const headerLeftRect = headerLeft?.getBoundingClientRect();
      const headerActionsRect = headerActions?.getBoundingClientRect();
      const safeLeft = headerLeftRect
        ? headerLeftRect.right - headerRect.left + 18
        : 16;
      const safeRight = headerActionsRect
        ? headerActionsRect.left - headerRect.left - 18
        : headerRect.width - 16;
      const left = Math.max(16, bodyRect.left - headerRect.left, safeLeft);
      const width = Math.max(0, safeRight - left);

      header.style.setProperty("--reading-title-left", `${left}px`);
      header.style.setProperty("--reading-title-width", `${width}px`);
    };

    const syncFloatingActionPosition = () => {
      if (!floatingActions) {
        return;
      }

      const columnRect = scrollRoot.getBoundingClientRect();
      const actionRect = floatingActions.getBoundingClientRect();
      const actionWidth = Math.max(42, actionRect.width || 46);
      const viewportWidth = document.documentElement.clientWidth || window.innerWidth;
      const safeInset = 12;
      const desiredLeft = columnRect.right - actionWidth - 18;
      const left = Math.max(safeInset, Math.min(desiredLeft, viewportWidth - actionWidth - safeInset));
      const right = Math.max(safeInset, viewportWidth - left - actionWidth);

      document.documentElement.style.setProperty("--topic-actions-right", `${right}px`);
    };

    const setState = () => {
      ticking = false;

      syncTitlePosition();
      syncFloatingActionPosition();

      const scrolled = getScrollTop() > 16;
      const headerRect = header.getBoundingClientRect();
      const heroRect = hero.getBoundingClientRect();
      const titleStuck = scrolled && heroRect.bottom <= headerRect.bottom + 10;

      document.documentElement.dataset.readingMode = scrolled ? "true" : "";
      document.documentElement.dataset.topicTitleStuck = titleStuck ? "true" : "";

      if (!scrolled) {
        document.documentElement.removeAttribute("data-reading-mode");
      }

      if (!titleStuck) {
        document.documentElement.removeAttribute("data-topic-title-stuck");
      }
    };

    const requestUpdate = () => {
      if (ticking) {
        return;
      }

      ticking = true;
      window.requestAnimationFrame(setState);
    };

    const sidebarObserver = new MutationObserver(() => {
      requestUpdate();
      window.setTimeout(requestUpdate, 120);
      window.setTimeout(requestUpdate, 360);
      window.setTimeout(requestUpdate, 460);
    });

    sidebarObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-sidebar", "data-sidebar-animating"],
    });

    const revealReplies = (shouldScroll = true) => {
      if (!replies) {
        return;
      }

      replies.hidden = false;
      commentToggle?.setAttribute("aria-expanded", "true");

      if (shouldScroll) {
        replies.scrollIntoView({ block: "start", behavior: "smooth" });
      }
    };

    commentToggle?.addEventListener("click", () => {
      if (!replies) {
        return;
      }

      const shouldOpen = replies.hidden;

      replies.hidden = !shouldOpen;
      commentToggle.setAttribute("aria-expanded", shouldOpen ? "true" : "false");

      if (shouldOpen) {
        replies.scrollIntoView({ block: "start", behavior: "smooth" });
      }
    });

    if (window.location.hash.startsWith("#post-")) {
      revealReplies(false);
      window.requestAnimationFrame(() => {
        const target = document.getElementById(window.location.hash.slice(1));
        target?.scrollIntoView({ block: "start" });
      });
    }

    const updateInteractionButton = (form, enabled, count) => {
      const button = form.querySelector("[data-topic-interaction-button]");
      const countNode = form.querySelector("[data-topic-interaction-count]");
      const activeLabel = form.getAttribute("data-active-label") || "";
      const inactiveLabel = form.getAttribute("data-inactive-label") || "";
      const label = enabled ? activeLabel : inactiveLabel;

      button?.classList.toggle("is-active", enabled);

      if (countNode) {
        countNode.textContent = String(Math.max(0, Number(count) || 0));
      }

      if (button && label) {
        button.setAttribute("aria-label", `${label} ${Math.max(0, Number(count) || 0)}`);
      }
    };

    page.querySelectorAll("[data-topic-interaction-form]").forEach((form) => {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const button = form.querySelector("[data-topic-interaction-button]");

        if (!(form instanceof HTMLFormElement) || button?.hasAttribute("disabled")) {
          return;
        }

        button?.setAttribute("disabled", "disabled");

        try {
          const response = await window.fetch(form.action, {
            method: form.method || "POST",
            headers: {
              accept: "application/json",
              "x-requested-with": "fetch",
            },
            body: new FormData(form),
          });
          const data = await response.json().catch(() => ({}));

          if (response.status === 401 && data.loginUrl) {
            window.location.assign(String(data.loginUrl));
            return;
          }

          if (!response.ok || !data.ok) {
            return;
          }

          updateInteractionButton(form, Boolean(data.enabled), data.count);
          requestUpdate();
        } finally {
          button?.removeAttribute("disabled");
        }
      });
    });

    const flashShareState = () => {
      if (!shareButton) {
        return;
      }

      const defaultLabel = shareButton.getAttribute("data-share-label") || "";
      const copiedLabel = shareButton.getAttribute("data-share-copied") || defaultLabel;

      shareButton.dataset.copyState = "copied";
      shareButton.setAttribute("aria-label", copiedLabel);
      window.setTimeout(() => {
        delete shareButton.dataset.copyState;
        shareButton.setAttribute("aria-label", `${defaultLabel} 0`);
      }, 1400);
    };

    const copyShareUrl = async (url) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(url);
        return;
      }

      const input = document.createElement("textarea");
      input.value = url;
      input.setAttribute("readonly", "");
      input.style.position = "fixed";
      input.style.left = "-999px";
      document.body.append(input);
      input.select();
      document.execCommand("copy");
      input.remove();
    };

    shareButton?.addEventListener("click", async () => {
      const url = shareButton.getAttribute("data-share-url") || window.location.href;
      const shareTitle = shareButton.getAttribute("data-share-title") || title;

      try {
        if (navigator.share) {
          await navigator.share({ title: shareTitle, url });
          return;
        }

        await copyShareUrl(url);
        flashShareState();
      } catch {
        await copyShareUrl(url);
        flashShareState();
      }
    });

    const getActiveScroller = () => {
      const rootCanScroll = scrollRoot.scrollHeight - scrollRoot.clientHeight > 8;
      return rootCanScroll ? scrollRoot : document.scrollingElement || document.documentElement;
    };

    const getRemainingScroll = () => {
      const activeScroller = getActiveScroller();
      return activeScroller.scrollHeight - activeScroller.scrollTop - activeScroller.clientHeight;
    };

    const currentTopicPath = window.location.pathname;
    const historyStorageKey = "whyisee_topic_reading_stack";
    const forwardHistoryStorageKey = "whyisee_topic_reading_forward_stack";
    const readingArrivalStorageKey = "whyisee_topic_reading_arrival";

    const queueReadingArrival = (targetUrl, direction) => {
      try {
        const parsed = new URL(targetUrl, window.location.origin);

        if (parsed.origin !== window.location.origin || !/^\/t\/\d+/.test(parsed.pathname)) {
          return;
        }

        window.sessionStorage.setItem(readingArrivalStorageKey, JSON.stringify({
          path: parsed.pathname,
          direction,
          createdAt: Date.now(),
        }));
      } catch {
        // The marker only preserves immersive reading position after navigation.
      }
    };

    const readReadingArrival = () => {
      try {
        const parsed = JSON.parse(window.sessionStorage.getItem(readingArrivalStorageKey) || "{}");

        if (!parsed || parsed.path !== currentTopicPath || Date.now() - Number(parsed.createdAt || 0) > 10000) {
          return undefined;
        }

        return parsed;
      } catch {
        return undefined;
      }
    };

    const clearReadingArrival = () => {
      try {
        window.sessionStorage.removeItem(readingArrivalStorageKey);
      } catch {
        // Ignore unavailable session storage.
      }
    };

    const scrollToReadingPosition = () => {
      const maxScrollTop = Math.max(0, scrollRoot.scrollHeight - scrollRoot.clientHeight);
      const titleElement = page.querySelector(".topic-title-stack h1");
      const titleRect = titleElement?.getBoundingClientRect();
      const headerRect = header.getBoundingClientRect();
      const targetScrollTop = Math.max(0, Math.min(
        titleRect ? getScrollTop() + titleRect.top - headerRect.bottom - 8 : hero.offsetTop + 20,
        maxScrollTop,
      ));

      scrollRoot.scrollTo({ top: targetScrollTop, left: 0, behavior: "auto" });
      document.documentElement.dataset.readingMode = "true";
      setState();
    };

    const restoreReadingArrival = () => {
      const arrival = readReadingArrival();

      if (!arrival) {
        document.documentElement.removeAttribute("data-reading-arriving");
        return false;
      }

      clearReadingArrival();

      if ("scrollRestoration" in window.history) {
        window.history.scrollRestoration = "manual";
      }

      document.documentElement.dataset.readingMode = "true";
      window.requestAnimationFrame(() => {
        scrollToReadingPosition();
        window.requestAnimationFrame(() => {
          scrollToReadingPosition();
          document.documentElement.removeAttribute("data-reading-arriving");
        });
      });

      return true;
    };

    const normalizeTopicPath = (value) => {
      if (!value) {
        return "";
      }

      try {
        const parsed = new URL(value, window.location.origin);

        if (parsed.origin !== window.location.origin || !/^\/t\/\d+/.test(parsed.pathname)) {
          return "";
        }

        return parsed.pathname === currentTopicPath ? "" : parsed.pathname;
      } catch {
        return "";
      }
    };

    const findRecommendationByUrl = (value) => {
      const targetPath = normalizeTopicPath(value);

      if (!targetPath) {
        return undefined;
      }

      return recommendationItems.find((item) => normalizeTopicPath(item.href) === targetPath);
    };

    const trackRecommendationClick = (targetUrl) => {
      const item = findRecommendationByUrl(targetUrl);

      if (!item) {
        return;
      }

      trackRecommendationEvent({
        eventType: "recommendation_click",
        targetType: "topic",
        targetId: Number(item.targetId || 0),
        sourceSurface: "reading",
        sourceReason: Array.isArray(item.reasons) ? item.reasons.join(" / ") : "",
        metadata: {
          href: item.href,
          score: Number(item.score || 0),
        },
      }, true);
    };

    const readTopicStack = (key) => {
      try {
        const parsed = JSON.parse(window.sessionStorage.getItem(key) || "[]");

        if (!Array.isArray(parsed)) {
          return [];
        }

        return parsed.map((item) => normalizeTopicPath(String(item))).filter(Boolean);
      } catch {
        return [];
      }
    };

    const writeTopicStack = (key, stack) => {
      try {
        window.sessionStorage.setItem(key, JSON.stringify(stack.slice(-50)));
      } catch {
        // Session storage is only used to make vertical reading reversible.
      }
    };

    const readHistoryStack = () => readTopicStack(historyStorageKey);
    const writeHistoryStack = (stack) => writeTopicStack(historyStorageKey, stack);
    const readForwardHistoryStack = () => readTopicStack(forwardHistoryStorageKey);
    const writeForwardHistoryStack = (stack) => writeTopicStack(forwardHistoryStorageKey, stack);

    const readNextTopicCandidates = () => {
      try {
        const parsed = JSON.parse(page.getAttribute("data-next-topic-urls") || "[]");

        if (!Array.isArray(parsed)) {
          return [];
        }

        return parsed.map((item) => normalizeTopicPath(String(item))).filter(Boolean);
      } catch {
        return normalizeTopicPath(nextTopicUrl) ? [normalizeTopicPath(nextTopicUrl)] : [];
      }
    };

    const getNextTopicUrl = () => {
      const stack = readHistoryStack();
      const seenTopics = new Set(stack);
      const candidates = readNextTopicCandidates();

      return candidates.find((candidate) => !seenTopics.has(candidate)) || "";
    };

    const pushCurrentTopicToHistory = () => {
      const stack = readHistoryStack().filter((item) => item !== currentTopicPath);
      stack.push(currentTopicPath);
      writeHistoryStack(stack);
    };

    const pushCurrentTopicToForwardHistory = () => {
      const stack = readForwardHistoryStack().filter((item) => item !== currentTopicPath);
      stack.push(currentTopicPath);
      writeForwardHistoryStack(stack);
    };

    const popPreviousTopicFromHistory = () => {
      const stack = readHistoryStack();

      while (stack.length > 0) {
        const previousTopicUrl = normalizeTopicPath(stack.pop() || "");

        if (previousTopicUrl) {
          writeHistoryStack(stack);
          return previousTopicUrl;
        }
      }

      writeHistoryStack([]);
      return "";
    };

    const popNextTopicFromForwardHistory = () => {
      const stack = readForwardHistoryStack();

      while (stack.length > 0) {
        const nextTopicFromHistory = normalizeTopicPath(stack.pop() || "");

        if (nextTopicFromHistory) {
          writeForwardHistoryStack(stack);
          return nextTopicFromHistory;
        }
      }

      writeForwardHistoryStack([]);
      return "";
    };

    let boundaryToast;
    let boundaryToastTimer = 0;
    let boundaryToastLock = 0;

    const showBoundaryMessage = (message) => {
      if (!message) {
        return;
      }

      const now = Date.now();

      if (now - boundaryToastLock < 760) {
        return;
      }

      boundaryToastLock = now;

      if (!boundaryToast) {
        boundaryToast = document.createElement("div");
        boundaryToast.className = "topic-reading-boundary-toast";
        boundaryToast.setAttribute("role", "status");
        boundaryToast.setAttribute("aria-live", "polite");
        document.body.append(boundaryToast);
      }

      boundaryToast.textContent = message;
      boundaryToast.dataset.visible = "true";
      window.clearTimeout(boundaryToastTimer);
      boundaryToastTimer = window.setTimeout(() => {
        boundaryToast?.removeAttribute("data-visible");
      }, 1400);
    };

    const navigateReadingTopic = (targetUrl, direction) => {
      queueReadingArrival(targetUrl, direction);
      window.location.assign(targetUrl);
    };

    let navigatingBetweenTopics = false;

    const navigateToNextTopic = () => {
      const restoredTopicUrl = popNextTopicFromForwardHistory();
      const targetUrl = restoredTopicUrl || getNextTopicUrl();

      if (!targetUrl) {
        showBoundaryMessage(noNextTopicMessage);
        return;
      }

      if (navigatingBetweenTopics) {
        return;
      }

      navigatingBetweenTopics = true;
      pushCurrentTopicToHistory();
      if (!restoredTopicUrl) {
        trackRecommendationClick(targetUrl);
      }
      navigateReadingTopic(targetUrl, "next");
    };

    const navigateToPreviousTopic = () => {
      if (navigatingBetweenTopics) {
        return;
      }

      const previousTopicUrl = popPreviousTopicFromHistory();

      if (!previousTopicUrl) {
        showBoundaryMessage(noPreviousTopicMessage);
        return;
      }

      navigatingBetweenTopics = true;
      pushCurrentTopicToForwardHistory();
      navigateReadingTopic(previousTopicUrl, "previous");
    };

    const boundaryDistance = 28;
    const wheelBoundaryThreshold = 128;
    const touchBoundaryThreshold = 108;
    let boundaryWheelDelta = 0;
    let boundaryWheelDirection = "";
    let boundaryWheelTimer = 0;
    let touchBoundaryDelta = 0;
    let touchBoundaryDirection = "";

    const isReadingAtBottom = () => getRemainingScroll() <= boundaryDistance;
    const isReadingAtTop = () => getScrollTop() <= boundaryDistance;

    const resetWheelBoundaryDelta = () => {
      boundaryWheelDelta = 0;
      boundaryWheelDirection = "";
      window.clearTimeout(boundaryWheelTimer);
    };

    const addWheelBoundaryDelta = (direction, amount) => {
      if (boundaryWheelDirection && boundaryWheelDirection !== direction) {
        boundaryWheelDelta = 0;
      }

      boundaryWheelDirection = direction;
      boundaryWheelDelta += Math.abs(amount);
      window.clearTimeout(boundaryWheelTimer);
      boundaryWheelTimer = window.setTimeout(resetWheelBoundaryDelta, 520);

      return boundaryWheelDelta >= wheelBoundaryThreshold;
    };

    const resetTouchBoundaryDelta = () => {
      touchBoundaryDelta = 0;
      touchBoundaryDirection = "";
    };

    const addTouchBoundaryDelta = (direction, amount) => {
      if (touchBoundaryDirection && touchBoundaryDirection !== direction) {
        touchBoundaryDelta = 0;
      }

      touchBoundaryDirection = direction;
      touchBoundaryDelta += Math.abs(amount);
      return touchBoundaryDelta >= touchBoundaryThreshold;
    };

    const handleContinuedWheel = (event) => {
      if (event.__whyiseeReadingWheelHandled) {
        return;
      }

      event.__whyiseeReadingWheelHandled = true;

      if (navigatingBetweenTopics || Math.abs(event.deltaY) <= 1) {
        return;
      }

      if (event.deltaY > 0 && isReadingAtBottom()) {
        if (addWheelBoundaryDelta("next", event.deltaY)) {
          resetWheelBoundaryDelta();
          navigateToNextTopic();
        }
      } else if (event.deltaY < 0 && isReadingAtTop()) {
        if (addWheelBoundaryDelta("previous", event.deltaY)) {
          resetWheelBoundaryDelta();
          navigateToPreviousTopic();
        }
      } else {
        resetWheelBoundaryDelta();
      }
    };

    let touchStartY = 0;
    let touchLastY = 0;

    page.addEventListener("touchstart", (event) => {
      touchStartY = event.touches[0]?.clientY || 0;
      touchLastY = touchStartY;
      resetTouchBoundaryDelta();
    }, { passive: true });

    page.addEventListener("touchmove", (event) => {
      const currentY = event.touches[0]?.clientY || touchStartY;
      const deltaY = touchLastY - currentY;
      touchLastY = currentY;

      if (Math.abs(deltaY) <= 1 || navigatingBetweenTopics) {
        return;
      }

      if (deltaY > 0 && isReadingAtBottom()) {
        if (addTouchBoundaryDelta("next", deltaY)) {
          resetTouchBoundaryDelta();
          navigateToNextTopic();
        }
      } else if (deltaY < 0 && isReadingAtTop()) {
        if (addTouchBoundaryDelta("previous", deltaY)) {
          resetTouchBoundaryDelta();
          navigateToPreviousTopic();
        }
      } else {
        resetTouchBoundaryDelta();
      }
    }, { passive: true });

    page.addEventListener("touchend", resetTouchBoundaryDelta, { passive: true });
    page.addEventListener("touchcancel", resetTouchBoundaryDelta, { passive: true });

    scrollRoot.addEventListener("wheel", handleContinuedWheel, { passive: true });
    window.addEventListener("wheel", handleContinuedWheel, { passive: true });
    scrollRoot.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    if (!restoreReadingArrival()) {
      setState();
    }
  })();
</script>
