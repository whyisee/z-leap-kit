---
import BaseLayout from "@layouts/BaseLayout.astro";
import LeftNav from "@components/LeftNav.astro";
import MarkdownContent from "@components/MarkdownContent.astro";
import TopicAiController from "@components/TopicAiController.astro";
import TopicReplyController from "@components/TopicReplyController.astro";
import TopicReplySection from "@components/TopicReplySection.astro";
import { getSessionFromAstro } from "@lib/auth";
import { categoryPath, tagPath, topicPath } from "@lib/routes";
import { formatDate, formatRelative } from "@lib/format";
import { getLangFromAstro, t } from "@lib/i18n";
import { enhanceMarkdownHtml } from "@lib/markdown";
import { listCategories, listTags } from "@server/services/categories";
import { countTargetLikes, getTopicInteractionState, userLikedTarget } from "@server/services/interactions";
import { listPostsForTopic } from "@server/services/posts";
import { getTopicById, listRelatedTopics } from "@server/services/topics";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);
const id = Number(Astro.params.id || 0);
const topic = await getTopicById(id, lang);

const topicUrl = `${Astro.url.origin}${Astro.url.pathname}`;

if (!topic) {
  Astro.response.status = 404;
}

const related = topic ? await listRelatedTopics(topic, 4, lang) : [];
const posts = topic ? await listPostsForTopic(topic.id, session?.userId) : [];
const topicInteraction = topic ? await getTopicInteractionState(topic.id, session?.userId) : undefined;
const postInteractionEntries = await Promise.all(
  posts.map(async (post) => [
    post.id,
    {
      likeCount: await countTargetLikes("post", post.id),
      liked: await userLikedTarget("post", post.id, session?.userId),
    },
  ] as const),
);
const postInteractions = new Map(postInteractionEntries);
const avatarInitial = (value: string | undefined, fallback = "W") => {
  const initial = value?.trim().slice(0, 1);
  return initial ? initial.toUpperCase() : fallback;
};
const currentUserInitial = avatarInitial(session?.displayName || session?.username);
const allReplyItems = posts.map((post) => {
  const interaction = postInteractions.get(post.id);
  const createdAtMs = Date.parse(post.createdAt);

  return {
    post,
    authorInitial: avatarInitial(post.author.displayName || post.author.username),
    contentHtml: enhanceMarkdownHtml(post.contentHtml),
    likeCount: interaction?.likeCount ?? 0,
    liked: interaction?.liked ?? false,
    createdAtMs: Number.isNaN(createdAtMs) ? 0 : createdAtMs,
  };
});
type ReplyItem = (typeof allReplyItems)[number];
const postIds = new Set(posts.map((post) => post.id));
const childRepliesByParentId = new Map<number, ReplyItem[]>();
const replyItems: ReplyItem[] = [];

for (const item of allReplyItems) {
  const parentPostId = item.post.parentPostId;

  if (parentPostId && postIds.has(parentPostId)) {
    const children = childRepliesByParentId.get(parentPostId) || [];
    children.push(item);
    childRepliesByParentId.set(parentPostId, children);
  } else if (!parentPostId) {
    replyItems.push(item);
  }
}

replyItems.sort((a, b) => b.likeCount - a.likeCount || b.createdAtMs - a.createdAtMs || b.post.id - a.post.id);
childRepliesByParentId.forEach((children) => {
  children.sort((a, b) => b.likeCount - a.likeCount || b.createdAtMs - a.createdAtMs || b.post.id - a.post.id);
});
const categories = await listCategories(lang);
const tags = await listTags(lang);
const replyError = Astro.url.searchParams.get("replyError") === "1";
const copy = lang === "en"
  ? {
      comments: "Comments",
      replies: "Replies",
      reply: "Reply",
      replyPlaceholder: "Add a thoughtful comment...",
      submitReply: "Post reply",
      loginToReply: "Log in to reply",
      noReplies: "No replies yet. Start the conversation.",
      replyError: "Reply failed. Please check the content and try again.",
      sortHot: "Hot",
      sortLatest: "Latest",
      uploadImage: "Upload image",
      mentionUser: "Mention user or bot",
      emoji: "Emoji",
      replyToComment: "Reply",
      cancelReply: "Cancel",
      inlineReplyPlaceholder: "Reply to this comment...",
      showNestedReplies: "View replies",
      hideNestedReplies: "Hide replies",
      moreActions: "More actions",
      copyCommentLink: "Copy comment link",
      copiedCommentLink: "Copied",
      blockUser: "Block user",
      editReply: "Edit",
      like: "Like",
      liked: "Liked",
      bookmark: "Bookmark",
      bookmarked: "Bookmarked",
      follow: "Follow",
      following: "Following",
      report: "Report",
      aiButton: "AI",
      aiMenuLabel: "AI tools",
      aiLoading: "AI is thinking...",
      aiError: "AI request failed. Please try again later.",
      aiLoginRequired: "Please log in before using AI tools.",
      aiNotConfigured: "AI model is not configured yet. Ask an admin to configure it in AI Settings.",
      aiKeyMissing: "The default AI model is missing an API key.",
      aiTimeout: "AI request timed out. Try again with a shorter topic.",
      aiCopy: "Copy",
      aiCopied: "Copied",
      aiClose: "Close",
      aiResultMeta: "Generated by",
      author: "Author",
      topicOwner: "Topic owner",
      signatureFallback: "No signature yet.",
      joined: "Joined",
      profile: "View profile",
      role: "Role",
    }
  : {
      comments: "评论",
      replies: "回复",
      reply: "回复",
      replyPlaceholder: "你渴望拥有力量吗？评论让力量更强大",
      submitReply: "发布",
      loginToReply: "登录后回复",
      noReplies: "还没有回复，来开个头。",
      replyError: "回复失败，请检查内容后重试。",
      sortHot: "最热",
      sortLatest: "最新",
      uploadImage: "上传图片",
      mentionUser: "@ 用户或机器人",
      emoji: "表情包",
      replyToComment: "回复",
      cancelReply: "取消",
      inlineReplyPlaceholder: "回复这条评论...",
      showNestedReplies: "查看回复",
      hideNestedReplies: "收起回复",
      moreActions: "更多操作",
      copyCommentLink: "复制评论链接",
      copiedCommentLink: "已复制",
      blockUser: "加入黑名单",
      editReply: "编辑",
      like: "点赞",
      liked: "已点赞",
      bookmark: "收藏",
      bookmarked: "已收藏",
      follow: "关注",
      following: "已关注",
      report: "举报",
      aiButton: "AI",
      aiMenuLabel: "AI 工具",
      aiLoading: "AI 正在思考...",
      aiError: "AI 请求失败，请稍后再试。",
      aiLoginRequired: "请先登录后再使用 AI 工具。",
      aiNotConfigured: "还没有配置 AI 模型，请先到 AI 配置里设置默认模型。",
      aiKeyMissing: "默认 AI 模型缺少 API Key。",
      aiTimeout: "AI 请求超时，可以换一个较短的话题再试。",
      aiCopy: "复制",
      aiCopied: "已复制",
      aiClose: "关闭",
      aiResultMeta: "生成模型",
      author: "作者",
      topicOwner: "楼主",
      signatureFallback: "还没有填写签名。",
      joined: "加入",
      profile: "查看主页",
      role: "身份",
    };
const aiActions = lang === "en"
  ? [
      ["summarize", "Summarize", "Key points and context"],
      ["draft-reply", "Draft reply", "A thoughtful reply outline"],
      ["translate", "Translate", "Chinese and English reading version"],
      ["extract-actions", "Extract actions", "Tasks, risks, and next steps"],
      ["find-related", "Find related", "Similar topics and tags"],
      ["quality-check", "Quality check", "Title, category, and content review"],
    ]
  : [
      ["summarize", "总结话题", "要点、背景和结论"],
      ["draft-reply", "生成回复", "给出有信息量的回复草稿"],
      ["translate", "双语翻译", "中文和英文阅读版本"],
      ["extract-actions", "提炼行动项", "任务、风险和下一步"],
      ["find-related", "查找相关", "相似话题和标签建议"],
      ["quality-check", "质量检查", "标题、分类和内容建议"],
    ];
---

<BaseLayout title={`${topic?.title ?? t(lang, "topic.notFound")} - whyisee.xyz`} description={topic?.summary ?? t(lang, "topic.notFound")}>
  {topic ? (
    <section class="page-grid topic-layout">
      <LeftNav categories={categories} tags={tags} lang={lang} activeCategorySlug={topic.category.slug} />

      <div class="content-column">
        <article class="topic-page">
          <header class="topic-hero">
            <div class="topic-hero-bar">
              <div class="topic-title-stack">
                <h1>{topic.title}</h1>
                <div class="topic-taxonomy-row">
                  <a class="category-pill" href={categoryPath(topic.category.slug)} style={`--pill-color: ${topic.category.color}`}>
                    {topic.category.name}
                  </a>
                  {topic.tags.map((tag) => <a class="topic-tag-pill" href={tagPath(tag.slug)}>#{tag.name}</a>)}
                </div>
              </div>

              <div class="topic-ai-menu" data-topic-ai-menu data-topic-id={topic.id}>
                <button
                  class="ai-tool-button"
                  type="button"
                  aria-haspopup="menu"
                  aria-expanded="false"
                  aria-label={copy.aiMenuLabel}
                  data-topic-ai-button
                >
                  <span class="ai-tool-mark" aria-hidden="true">AI</span>
                  <span>{copy.aiButton}</span>
                  <span class="ai-tool-chevron" aria-hidden="true">⌄</span>
                </button>
                <div class="topic-ai-panel" role="menu" aria-label={copy.aiMenuLabel} data-topic-ai-panel hidden>
                  {aiActions.map(([id, label, description]) => (
                    <button class="topic-ai-option" type="button" role="menuitem" data-ai-action={id}>
                      <strong>{label}</strong>
                      <span>{description}</span>
                    </button>
                  ))}
                </div>
              </div>
            </div>
          </header>

          <section class="topic-post-frame">
            <div class="topic-author-card">
              <div class="topic-author-hover topic-author-avatar-hover">
                <button class="topic-author-avatar-trigger" type="button" aria-haspopup="dialog" aria-label={topic.author.displayName}>
                  <span class="topic-author-avatar" aria-hidden="true">
                    {topic.author.avatarUrl
                      ? <img src={topic.author.avatarUrl} alt="" loading="lazy" />
                      : avatarInitial(topic.author.displayName || topic.author.username)}
                  </span>
                </button>
                <div class="topic-author-popover" role="dialog" aria-label={topic.author.displayName}>
                  <div class="topic-author-popover-head">
                    <span class="topic-author-popover-avatar" aria-hidden="true">
                      {topic.author.avatarUrl
                        ? <img src={topic.author.avatarUrl} alt="" loading="lazy" />
                        : avatarInitial(topic.author.displayName || topic.author.username)}
                    </span>
                    <div>
                      <strong>{topic.author.displayName}</strong>
                      <span>@{topic.author.username}</span>
                    </div>
                  </div>
                  <p>{topic.author.bio || copy.signatureFallback}</p>
                  <div class="topic-author-popover-meta">
                    <span>{copy.role}: {topic.author.role}</span>
                    {topic.author.createdAt && <span>{copy.joined}: {formatDate(topic.author.createdAt, lang)}</span>}
                  </div>
                  <a class="button secondary compact" href={`/u/${topic.author.username}`}>{copy.profile}</a>
                </div>
              </div>
            </div>

            <div class="topic-post-body">
              <div class="topic-post-head">
                <div class="topic-author-inline">
                  <div class="topic-author-hover">
                    <button class="topic-author-name-trigger" type="button" aria-haspopup="dialog">
                      {topic.author.displayName}
                    </button>
                    <div class="topic-author-popover" role="dialog" aria-label={topic.author.displayName}>
                      <div class="topic-author-popover-head">
                        <span class="topic-author-popover-avatar" aria-hidden="true">
                          {topic.author.avatarUrl
                            ? <img src={topic.author.avatarUrl} alt="" loading="lazy" />
                            : avatarInitial(topic.author.displayName || topic.author.username)}
                        </span>
                        <div>
                          <strong>{topic.author.displayName}</strong>
                          <span>@{topic.author.username}</span>
                        </div>
                      </div>
                      <p>{topic.author.bio || copy.signatureFallback}</p>
                      <div class="topic-author-popover-meta">
                        <span>{copy.role}: {topic.author.role}</span>
                        {topic.author.createdAt && <span>{copy.joined}: {formatDate(topic.author.createdAt, lang)}</span>}
                      </div>
                      <a class="button secondary compact" href={`/u/${topic.author.username}`}>{copy.profile}</a>
                    </div>
                  </div>
                  <span class="topic-author-username">@{topic.author.username}</span>
                  <p class="topic-author-signature">{topic.author.bio || copy.signatureFallback}</p>
                  <span class="topic-post-time">{formatRelative(topic.publishedAt, lang)}</span>
                </div>
              </div>
              <MarkdownContent html={topic.contentHtml} />

              <div class="topic-action-strip">
                <form method="post" action="/api/interactions/reaction">
                  <input type="hidden" name="targetType" value="topic" />
                  <input type="hidden" name="targetId" value={topic.id} />
                  <input type="hidden" name="redirect" value={Astro.url.pathname} />
                  <button class:list={["action-button", topicInteraction?.liked && "is-active"]} type="submit">
                    {topicInteraction?.liked ? copy.liked : copy.like}
                    <span>{topicInteraction?.likeCount ?? 0}</span>
                  </button>
                </form>
                <form method="post" action="/api/interactions/bookmark">
                  <input type="hidden" name="topicId" value={topic.id} />
                  <input type="hidden" name="redirect" value={Astro.url.pathname} />
                  <button class:list={["action-button", topicInteraction?.bookmarked && "is-active"]} type="submit">
                    {topicInteraction?.bookmarked ? copy.bookmarked : copy.bookmark}
                  </button>
                </form>
                <form method="post" action="/api/interactions/follow">
                  <input type="hidden" name="targetType" value="topic" />
                  <input type="hidden" name="targetId" value={topic.id} />
                  <input type="hidden" name="redirect" value={Astro.url.pathname} />
                  <button class:list={["action-button", topicInteraction?.followed && "is-active"]} type="submit">
                    {topicInteraction?.followed ? copy.following : copy.follow}
                  </button>
                </form>
                <a class="action-button" href={`/report?targetType=topic&targetId=${topic.id}&redirect=${encodeURIComponent(Astro.url.pathname)}`}>{copy.report}</a>
              </div>
            </div>
          </section>

          <section
            class="topic-ai-result"
            data-topic-ai-result
            data-loading={copy.aiLoading}
            data-error={copy.aiError}
            data-login-required={copy.aiLoginRequired}
            data-not-configured={copy.aiNotConfigured}
            data-key-missing={copy.aiKeyMissing}
            data-timeout={copy.aiTimeout}
            data-copy={copy.aiCopy}
            data-copied={copy.aiCopied}
            data-result-meta={copy.aiResultMeta}
            hidden
          >
            <header class="topic-ai-result-head">
              <div>
                <p class="eyebrow">{copy.aiButton}</p>
                <h2 data-topic-ai-title>{copy.aiMenuLabel}</h2>
              </div>
              <div class="topic-ai-result-actions">
                <button class="action-button compact" type="button" data-topic-ai-copy>{copy.aiCopy}</button>
                <button class="action-button compact" type="button" data-topic-ai-close>{copy.aiClose}</button>
              </div>
            </header>
            <pre data-topic-ai-output></pre>
            <footer data-topic-ai-meta hidden></footer>
          </section>

          <TopicReplySection
            childRepliesByParentId={childRepliesByParentId}
            copy={copy}
            currentPath={Astro.url.pathname}
            currentUserInitial={currentUserInitial}
            lang={lang}
            postCount={posts.length}
            replyError={replyError}
            replyItems={replyItems}
            session={session}
            topicId={topic.id}
            topicUrl={topicUrl}
          />
        </article>
      </div>

      <aside class="sidebar">
        <section class="side-panel">
          <h2>{t(lang, "topic.info")}</h2>
          <div class="topic-side-meta">
            <span>{copy.author} <strong><a href={`/u/${topic.author.username}`}>{topic.author.displayName}</a></strong></span>
            <span>{t(lang, "topic.replies")} <strong>{topic.replyCount}</strong></span>
            <span>{t(lang, "topic.views")} <strong>{topic.viewCount}</strong></span>
            <span>{t(lang, "topic.published")} <strong>{formatDate(topic.publishedAt, lang)}</strong></span>
          </div>
        </section>

        {related.length > 0 && (
          <section class="side-panel">
            <h2>{t(lang, "topic.related")}</h2>
            <div class="compact-list">
              {related.map((item) => <a href={topicPath(item)}>{item.title}</a>)}
            </div>
          </section>
        )}
      </aside>
    </section>
  ) : (
    <section class="article-page">
      <h1>{t(lang, "topic.notFound")}</h1>
      <p>{t(lang, "topic.notFoundDescription")}</p>
    </section>
  )}
</BaseLayout>

<TopicAiController />
<TopicReplyController />
