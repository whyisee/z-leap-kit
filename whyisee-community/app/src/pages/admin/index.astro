---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro } from "@lib/auth";
import { getLangFromAstro, t } from "@lib/i18n";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = getSessionFromAstro(Astro);

if (!session) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(Astro.url.pathname)}`, 303);
}
---

<BaseLayout title={`${t(lang, "admin.title")} - whyisee.xyz`} description={t(lang, "admin.description")}>
  <section class="article-page">
    <p class="eyebrow">{t(lang, "admin.title")}</p>
    <h1>{t(lang, "admin.title")}</h1>
    <p>{t(lang, "admin.description")}</p>
    <p class="auth-message muted">{t(lang, "auth.loggedInAs")}：{session.displayName}</p>
    <div class="admin-actions">
      <a class="button primary" href="/admin/topics/new">{t(lang, "admin.newTopic")}</a>
      <a class="button secondary" href="/latest">{t(lang, "admin.backToSite")}</a>
      <form method="post" action="/api/logout?redirect=/">
        <button class="button secondary" type="submit">{t(lang, "auth.logout")}</button>
      </form>
    </div>
  </section>
</BaseLayout>
