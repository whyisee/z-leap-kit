---
import AdminTopicForm from "@components/AdminTopicForm.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro, isAdmin } from "@lib/auth";
import { getLangFromAstro } from "@lib/i18n";
import { listCategories, listTags } from "@server/services/categories";
import { getTopicByIdForAdmin } from "@server/services/topics";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);
const id = Number(Astro.params.id || 0);
const topic = Number.isFinite(id) ? await getTopicByIdForAdmin(id, lang) : undefined;

if (!session) {
  return Astro.redirect(`/login?redirect=${encodeURIComponent(Astro.url.pathname)}`, 303);
}

if (!topic || (topic.authorId !== session.userId && !isAdmin(session))) {
  Astro.response.status = 404;
}

const categories = await listCategories(lang);
const tags = await listTags(lang);
const saved = Astro.url.searchParams.get("saved") === "1";
const error = Astro.url.searchParams.get("error") === "1";
const copy = lang === "en"
  ? {
      title: "Edit topic",
      description: "Changes from regular users will return to review before becoming public.",
      save: "Submit",
      saved: "Topic saved.",
      notFound: "Topic not found",
    }
  : {
      title: "编辑话题",
      description: "普通用户修改后会重新进入审核，通过后再公开展示。",
      save: "提交",
      saved: "话题已保存。",
      notFound: "话题未找到",
    };
---

<BaseLayout title={`${copy.title} - whyisee.xyz`} description={copy.description}>
  {topic && (topic.authorId === session?.userId || isAdmin(session)) ? (
    <section class="article-page new-topic-page topic-edit-page">
      <AdminTopicForm
        action={`/api/topics/${topic.id}`}
        categories={categories}
        tags={tags}
        lang={lang}
        topic={topic}
        error={error}
        submitLabel={copy.save}
        cancelHref={`/u/${session.username}`}
        showAdminFields={false}
        forcedStatus="pending"
        savedMessage={saved ? copy.saved : ""}
      />
    </section>
  ) : (
    <section class="article-page">
      <h1>{copy.notFound}</h1>
    </section>
  )}
</BaseLayout>
