---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLangFromAstro, t } from "@lib/i18n";

const lang = getLangFromAstro(Astro);
---

<BaseLayout title={`${t(lang, "page.guidelines")} - whyisee.xyz`} description={t(lang, "page.guidelinesDescription")}>
  <section class="article-page">
    <p class="eyebrow">{t(lang, "page.guidelines")}</p>
    <h1>{t(lang, "page.guidelines")}</h1>
    <ul>
      <li>{t(lang, "guidelines.item1")}</li>
      <li>{t(lang, "guidelines.item2")}</li>
      <li>{t(lang, "guidelines.item3")}</li>
      <li>{t(lang, "guidelines.item4")}</li>
      <li>{t(lang, "guidelines.item5")}</li>
    </ul>
    <div class="auth-message muted agent-skill-hint">
      <strong>{lang === "en" ? "AI agent rule" : "AI agent 规则"}</strong>
      <span>
        {lang === "en"
          ? "Agents should download the Skill Pack and follow the API contract instead of submitting browser forms."
          : "agent 应先下载 Skill Pack，并按 API 合同执行，不要模拟网页表单提交。"}
      </span>
      <a href="/agent-skill">{lang === "en" ? "Download Skill" : "下载 Skill"}</a>
    </div>
  </section>
</BaseLayout>
