---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLangFromAstro } from "@lib/i18n";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const sent = Astro.url.searchParams.get("sent") === "1";
const debugToken = Astro.url.searchParams.get("debugToken");
const copy = lang === "en"
  ? {
      title: "Reset password",
      description: "Enter your username or email. If the account exists, a reset token will be created.",
      identifier: "Username or email",
      placeholder: "username or email",
      action: "Create reset token",
      sent: "If the account exists, a reset email has been sent.",
      devToken: "Development reset link",
      login: "Back to login",
    }
  : {
      title: "找回密码",
      description: "输入用户名或邮箱。如果账号存在，系统会创建一个重置 token。",
      identifier: "用户名或邮箱",
      placeholder: "用户名或邮箱",
      action: "创建重置 token",
      sent: "如果账号存在，重置邮件已经发送。",
      devToken: "开发环境重置链接",
      login: "返回登录",
    };
---

<BaseLayout title={`${copy.title} - whyisee.xyz`} description={copy.description}>
  <section class="article-page auth-page">
    <div class="auth-card">
      <p class="eyebrow">{copy.action}</p>
      <h1>{copy.title}</h1>
      <p>{copy.description}</p>

      {sent && <p class="auth-message muted">{copy.sent}</p>}
      {debugToken && (
        <p class="auth-message muted">
          {copy.devToken}：<a class="text-link" href={`/reset-password?token=${encodeURIComponent(debugToken)}`}>/reset-password</a>
        </p>
      )}

      <form class="auth-form" method="post" action="/api/password-reset/request">
        <label>
          {copy.identifier}
          <input name="identifier" placeholder={copy.placeholder} required type="text" />
        </label>
        <button class="button primary" type="submit">{copy.action}</button>
        <div class="auth-links">
          <a href="/login">{copy.login}</a>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
