---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro } from "@lib/auth";
import { getLangFromAstro } from "@lib/i18n";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);

if (!session) {
  return Astro.redirect("/login?redirect=/settings/account", 303);
}

const hasError = Astro.url.searchParams.get("error") === "1";
const copy = lang === "en"
  ? {
      title: "Account security",
      description: "Change your password. All sessions will be signed out after the update.",
      currentPassword: "Current password",
      nextPassword: "New password",
      nextPasswordPlaceholder: "at least 8 characters",
      action: "Update password",
      error: "Password update failed. Check the current password and length.",
      profile: "Profile settings",
    }
  : {
      title: "账号安全",
      description: "修改密码后，当前账号的所有登录状态都会退出。",
      currentPassword: "当前密码",
      nextPassword: "新密码",
      nextPasswordPlaceholder: "至少 8 位",
      action: "更新密码",
      error: "密码更新失败，请检查当前密码和新密码长度。",
      profile: "个人资料设置",
    };
---

<BaseLayout title={`${copy.title} - whyisee.xyz`} description={copy.description}>
  <section class="article-page auth-page">
    <div class="auth-card">
      <p class="eyebrow">{session.username}</p>
      <h1>{copy.title}</h1>
      <p>{copy.description}</p>

      {hasError && <p class="auth-message error">{copy.error}</p>}

      <form class="auth-form" method="post" action="/api/settings/account">
        <label>
          {copy.currentPassword}
          <input autocomplete="current-password" name="currentPassword" required type="password" />
        </label>
        <label>
          {copy.nextPassword}
          <input autocomplete="new-password" name="nextPassword" placeholder={copy.nextPasswordPlaceholder} required type="password" />
        </label>
        <div class="form-actions">
          <button class="button primary" type="submit">{copy.action}</button>
          <a class="button secondary" href="/settings/profile">{copy.profile}</a>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
