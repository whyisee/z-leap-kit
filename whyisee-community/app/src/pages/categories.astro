---
import BaseLayout from "@layouts/BaseLayout.astro";
import ForumFrame from "@components/ForumFrame.astro";
import { getLangFromAstro, t } from "@lib/i18n";
import { categoryPath } from "@lib/routes";
import { listCategories, listTags } from "@server/services/categories";
import { listFeaturedTopics } from "@server/services/topics";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const categories = await listCategories(lang);
const tags = await listTags(lang);
const featuredTopics = await listFeaturedTopics(4, lang);
---

<BaseLayout title={`${t(lang, "nav.categories")} - whyisee.xyz`} description={t(lang, "page.categoriesDescription")}>
  <ForumFrame categories={categories} tags={tags} featuredTopics={featuredTopics} lang={lang}>
    <div class="section-head">
      <div>
        <p class="eyebrow">{t(lang, "page.categories")}</p>
        <h1>{t(lang, "page.categories")}</h1>
      </div>
    </div>
    <div class="category-grid">
      {categories.map((category) => (
        <a class="category-card" href={categoryPath(category.slug)} style={`--pill-color: ${category.color}`}>
          <span>{category.name}</span>
          <strong>{category.topicCount ?? 0}</strong>
          <p>{category.description}</p>
        </a>
      ))}
    </div>
  </ForumFrame>
</BaseLayout>
