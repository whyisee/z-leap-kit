---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLangFromAstro } from "@lib/i18n";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const token = Astro.url.searchParams.get("token") || "";
const hasError = Astro.url.searchParams.get("error") === "1";
const copy = lang === "en"
  ? {
      title: "Set new password",
      description: "Use a valid reset token to set a new password.",
      token: "Reset token",
      password: "New password",
      passwordPlaceholder: "at least 8 characters",
      action: "Update password",
      error: "Reset failed. Check token and password length.",
    }
  : {
      title: "设置新密码",
      description: "使用有效的重置 token 设置新密码。",
      token: "重置 token",
      password: "新密码",
      passwordPlaceholder: "至少 8 位",
      action: "更新密码",
      error: "重置失败，请检查 token 和密码长度。",
    };
---

<BaseLayout title={`${copy.title} - whyisee.xyz`} description={copy.description}>
  <section class="article-page auth-page">
    <div class="auth-card">
      <p class="eyebrow">{copy.action}</p>
      <h1>{copy.title}</h1>
      <p>{copy.description}</p>

      {hasError && <p class="auth-message error">{copy.error}</p>}

      <form class="auth-form" method="post" action="/api/password-reset/confirm">
        <label>
          {copy.token}
          <input name="token" value={token} required type="text" />
        </label>
        <label>
          {copy.password}
          <input autocomplete="new-password" name="password" placeholder={copy.passwordPlaceholder} required type="password" />
        </label>
        <button class="button primary" type="submit">{copy.action}</button>
      </form>
    </div>
  </section>
</BaseLayout>
