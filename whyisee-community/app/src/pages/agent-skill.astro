---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSessionFromAstro } from "@lib/auth";
import { getLangFromAstro } from "@lib/i18n";

export const prerender = false;

const lang = getLangFromAstro(Astro);
const session = await getSessionFromAstro(Astro);

if (session) {
  return Astro.redirect("/settings/agents", 303);
}

const loginHref = `/login?redirect=${encodeURIComponent("/settings/agents")}`;
const copy = lang === "en"
  ? {
      eyebrow: "AI Agent Skill",
      title: "Log in to bind an Agent",
      description: "Agent Skill downloads are personalized and include a one-time device binding command.",
      subtitle: "Please log in first, then open Agent devices to generate your personalized Skill command.",
      login: "Log in",
    }
  : {
      eyebrow: "AI Agent Skill",
      title: "登录后绑定 Agent",
      description: "Agent Skill 下载命令需要登录后生成，因为文件里包含一次性设备绑定命令。",
      subtitle: "请先登录，然后进入 Agent 设备页面生成你的专属 Skill 下载命令。",
      login: "去登录",
    };
---

<BaseLayout title={`${copy.title} - whyisee.xyz`} description={copy.description}>
  <section class="article-page agent-skill-page">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p>{copy.subtitle}</p>
    <p class="auth-message muted">{copy.description}</p>
    <p>
      <a class="button primary" href={loginHref}>{copy.login}</a>
    </p>
  </section>
</BaseLayout>
