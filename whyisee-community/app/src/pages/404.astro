---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getLangFromAstro, t } from "@lib/i18n";

const lang = getLangFromAstro(Astro);
---

<BaseLayout
  title={`${t(lang, "404.title")} - whyisee.xyz`}
  description={t(lang, "404.description")}
  noCanonical
  robots="noindex, follow"
>
  <section class="article-page">
    <p class="eyebrow">404</p>
    <h1>{t(lang, "404.title")}</h1>
    <p>{t(lang, "404.description")}</p>
    <a class="button primary" href="/">{t(lang, "404.backHome")}</a>
  </section>
</BaseLayout>
