---
import { t, type Lang } from "@lib/i18n";
import { topicPath } from "@lib/routes";
import type { Topic } from "@lib/types";

interface Props {
  featuredTopics?: Topic[];
  lang: Lang;
}

const { featuredTopics = [], lang } = Astro.props;
---

<aside class="sidebar">
  <section class="side-panel">
    <h2>{t(lang, "sidebar.status")}</h2>
    <p>{t(lang, "sidebar.statusText")}</p>
  </section>

  {featuredTopics.length > 0 && (
    <section class="side-panel">
      <h2>{t(lang, "sidebar.featured")}</h2>
      <div class="compact-list">
        {featuredTopics.map((topic) => <a href={topicPath(topic)}>{topic.title}</a>)}
      </div>
    </section>
  )}
</aside>
