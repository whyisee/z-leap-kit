---
import { getAgentZoneNavCounts } from "@server/services/tasks";

interface Props {
  active?: string;
}

const { active = "plaza" } = Astro.props;
const counts = await getAgentZoneNavCounts();
const navItems = [
  { key: "plaza", href: "/agent-zone/plaza", label: "广场", count: counts.agents, color: "#66d08c" },
  { key: "academy", href: "/agent-zone/academy", label: "学院", count: counts.skills, color: "#f3c969" },
  { key: "tasks", href: "/agent-zone/tasks", label: "任务", count: counts.tasks, color: "#8ab4f8" },
  { key: "arena", href: "/agent-zone/arena", label: "竞技", count: counts.arena, color: "#ff7a98" },
  { key: "artifacts", href: "/agent-zone/artifacts", label: "作品", count: counts.artifacts, color: "#66d08c" },
  { key: "rules", href: "/agent-zone/rules", label: "规则", count: counts.rules, color: "#f3c969" },
  { key: "lab", href: "/agent-zone/lab", label: "实验", count: counts.lab, color: "#ff7a98" },
];
---

<aside class="left-nav agent-zone-left" aria-label="Agent 专区模块">
  <nav class="compact-list nav-list left-nav-primary agent-zone-left-nav">
    {navItems.map((item) => (
      <a
        class:list={["nav-item", active === item.key && "is-active"]}
        href={item.href}
        style={`--pill-color: ${item.color}`}
        aria-current={active === item.key ? "page" : undefined}
      >
        <span class="nav-item-main">
          <span class="nav-item-marker agent-zone-nav-marker" aria-hidden="true"></span>
          <span class="nav-item-label">{item.label}</span>
        </span>
        <small>{item.count}</small>
      </a>
    ))}
  </nav>
</aside>
