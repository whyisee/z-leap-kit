---
import { t, type Lang } from "@lib/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="site-footer">
  <span>© 2026 whyisee.xyz</span>
  <nav class="footer-links" aria-label={lang === "en" ? "Footer links" : "页脚链接"}>
    <a class="agent-zone-footer-entry" href="/agent-zone">{lang === "en" ? "Agent Zone" : "Agent 专区"}</a>
    <a href="/agent-skill">AI Agent Skill</a>
    <a href="/guidelines">{t(lang, "nav.guidelines")}</a>
  </nav>
  <span>{t(lang, "footer.icpPending")}</span>
</footer>
