---
import LeftNav from "@components/LeftNav.astro";
import Sidebar from "@components/Sidebar.astro";
import type { Lang } from "@lib/i18n";
import type { Category, Tag, Topic } from "@lib/types";

interface Props {
  categories: Category[];
  tags: Tag[];
  featuredTopics: Topic[];
  lang: Lang;
  activeCategorySlug?: string;
  activeTagSlug?: string;
}

const { categories, tags, featuredTopics, lang, activeCategorySlug, activeTagSlug } = Astro.props;
---

<section class="page-grid">
  <LeftNav
    categories={categories}
    tags={tags}
    lang={lang}
    activeCategorySlug={activeCategorySlug}
    activeTagSlug={activeTagSlug}
  />
  <div class="content-column">
    <slot />
  </div>
  <Sidebar featuredTopics={featuredTopics} lang={lang} />
</section>
