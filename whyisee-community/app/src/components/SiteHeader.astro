---
import { getSessionFromAstro } from "@lib/auth";
import { t, type Lang } from "@lib/i18n";
import { countUnreadNotifications } from "@server/services/notifications";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const redirectParams = new URLSearchParams(Astro.url.searchParams);
redirectParams.delete("lang");
const redirectPath = `${Astro.url.pathname}${redirectParams.toString() ? `?${redirectParams.toString()}` : ""}`;
const session = await getSessionFromAstro(Astro);
const loginHref = `/login?redirect=${encodeURIComponent(redirectPath)}`;
const unreadNotifications = session ? await countUnreadNotifications(session.userId) : 0;
const searchLabel = lang === "en" ? "Search" : "搜索";
const newTopicLabel = lang === "en" ? "New topic" : "新建话题";
const newTopicHref = buildNewTopicHref(Astro.url);
const searchValue = Astro.url.pathname === "/search" ? Astro.url.searchParams.get("q") || "" : "";
const searchOpen = Astro.url.pathname === "/search";
const searchCopy = lang === "en"
  ? {
      loading: "Searching...",
      aiLoading: "AI is translating and searching...",
      aiSearching: "Searching with AI directives...",
      noResults: "No matching results.",
      error: "Search failed. Try again later.",
      aiSearch: "AI Search",
      hint: "Use directives like tag:seo, type:reply, mention:ai, or let AI translate natural language.",
      translated: "AI translated",
      plan: "Search",
      usedDirective: "Using",
      examples: ["tag:seo sort:hot", "type:reply mention:ai", "has:image sort:latest"],
    }
  : {
      loading: "搜索中...",
      aiLoading: "AI 正在理解并搜索...",
      aiSearching: "正在使用 AI 指令搜索...",
      noResults: "没有匹配结果。",
      error: "搜索失败，稍后再试。",
      aiSearch: "AI 搜索",
      hint: "支持 tag:seo、type:reply、mention:ai 等指令，也可以让 AI 把自然语言转成搜索条件。",
      translated: "AI 已翻译",
      plan: "搜索条件",
      usedDirective: "使用指令",
      examples: ["tag:seo sort:hot", "type:reply mention:ai", "has:image sort:latest"],
    };
const notificationLabel = lang === "en" ? "Notifications" : "通知";
const menuCopy = lang === "en"
  ? {
      profile: "Profile",
      topics: "Topics",
      admin: "Admin",
      logout: "Log out",
      settings: "Settings",
      unread: "unread",
    }
  : {
      profile: "资料",
      topics: "话题",
      admin: "管理",
      logout: "退出登录",
      settings: "设置",
      unread: "未读",
    };
const avatarLabel = session ? `${session.displayName || session.username}` : t(lang, "header.login");
const avatarInitial = session ? (session.displayName || session.username).trim().slice(0, 1).toUpperCase() : "";

function buildNewTopicHref(url: URL) {
  const parts = url.pathname.split("/").filter(Boolean);
  const params = new URLSearchParams();

  if (parts[0] === "c" && parts[1]) {
    params.set("category", parts[1]);

    const tag = url.searchParams.get("tag");
    if (tag) {
      params.set("tag", tag);
    }
  }

  if (parts[0] === "tag" && parts[1]) {
    params.set("tag", parts[1]);

    const category = url.searchParams.get("category");
    if (category) {
      params.set("category", category);
    }
  }

  const query = params.toString();
  return `/new-topic${query ? `?${query}` : ""}`;
}
---

<header class="site-header">
  <div class="header-left">
    <button
      class="sidebar-toggle"
      type="button"
      aria-label={t(lang, "header.sidebarToggle")}
      aria-expanded="true"
      title={t(lang, "header.sidebarCollapse")}
      data-expand-label={t(lang, "header.sidebarExpand")}
      data-collapse-label={t(lang, "header.sidebarCollapse")}
    >
      <span class="sidebar-toggle-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <a class="brand" href="/" aria-label="whyisee.xyz">
      <span class="brand-mark">W</span>
      <span>
        <strong>whyisee</strong>
        <small>{t(lang, "site.slogan")}</small>
      </span>
    </a>
  </div>

  <div class="header-actions">
    <a class="header-icon-button new-topic-button" href={newTopicHref} aria-label={newTopicLabel} title={newTopicLabel}>
      <span class="new-topic-icon" aria-hidden="true"></span>
    </a>

    <form
      class:list={["header-search", searchOpen && "is-open"]}
      method="get"
      action="/search"
      data-header-search
      data-search-lang={lang}
      data-search-loading={searchCopy.loading}
      data-search-ai-loading={searchCopy.aiLoading}
      data-search-ai-searching={searchCopy.aiSearching}
      data-search-empty={searchCopy.noResults}
      data-search-error={searchCopy.error}
      data-search-hint={searchCopy.hint}
      data-search-translated={searchCopy.translated}
      data-search-plan={searchCopy.plan}
      data-search-used-directive={searchCopy.usedDirective}
    >
      <button
        class="header-icon-button search-toggle"
        type="button"
        aria-label={searchLabel}
        aria-expanded={searchOpen ? "true" : "false"}
        data-search-toggle
      >
        <span class="search-icon" aria-hidden="true"></span>
      </button>
      <input
        class="header-search-input"
        name="q"
        value={searchValue}
        placeholder={searchLabel}
        autocomplete="off"
        tabindex={searchOpen ? "0" : "-1"}
        data-search-input
      />
      <div class="header-search-panel" data-search-panel hidden>
        <div class="header-search-tools">
          <button class="header-search-ai-button" type="button" data-header-ai-search>{searchCopy.aiSearch}</button>
          <div class="header-search-examples" aria-label={lang === "en" ? "Search examples" : "搜索示例"}>
            {searchCopy.examples.map((example) => (
              <button type="button" data-header-search-example={example}>{example}</button>
            ))}
          </div>
        </div>
        <div class="header-search-plan" data-header-search-plan hidden></div>
        <div class="header-search-state" data-search-state hidden></div>
        <div class="header-search-results" data-search-results></div>
      </div>
    </form>

    <form class="language-switch" method="post" action="/api/lang" data-language-switch>
      <input type="hidden" name="redirect" value={redirectPath} />
      <input type="hidden" name="lang" value={lang} data-language-input />
      <button
        class="language-button"
        type="button"
        aria-haspopup="menu"
        aria-expanded="false"
        aria-label={t(lang, "header.language")}
        data-language-button
      >
        <span>{lang === "zh" ? "ZH" : "EN"}</span>
        <span class="language-chevron" aria-hidden="true">⌄</span>
      </button>
      <div class="language-menu" role="menu" aria-label={t(lang, "header.language")} data-language-menu hidden>
        <button class:list={["language-option", lang === "zh" && "is-active"]} type="submit" role="menuitem" data-lang-value="zh">
          <span class="language-check" aria-hidden="true">{lang === "zh" ? "✓" : ""}</span>
          <span>中文</span>
          <small>ZH</small>
        </button>
        <button class:list={["language-option", lang === "en" && "is-active"]} type="submit" role="menuitem" data-lang-value="en">
          <span class="language-check" aria-hidden="true">{lang === "en" ? "✓" : ""}</span>
          <span>English</span>
          <small>EN</small>
        </button>
      </div>
    </form>

    {session ? (
      <div class="user-menu" data-user-menu>
        <button
          class:list={["avatar-button", unreadNotifications > 0 && "has-unread"]}
          type="button"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-label={avatarLabel}
          data-user-menu-button
        >
          <span class="avatar-mark" aria-hidden="true">{avatarInitial}</span>
        </button>
        <div class="user-menu-panel" role="menu" data-user-menu-panel hidden>
          <div class="user-menu-head">
            <span class="user-menu-head-avatar" aria-hidden="true">{avatarInitial}</span>
            <div>
              <strong>{session.displayName}</strong>
              <span>@{session.username}</span>
            </div>
          </div>
          <a class="user-menu-item" href="/notifications" role="menuitem">
            <span>{notificationLabel}</span>
            {unreadNotifications > 0 && <small>{unreadNotifications} {menuCopy.unread}</small>}
          </a>
          <div class="user-menu-divider" aria-hidden="true"></div>
          <a class="user-menu-item" href={`/u/${session.username}`} role="menuitem">{menuCopy.profile}</a>
          <a class="user-menu-item" href={`/u/${session.username}#topics`} role="menuitem">{menuCopy.topics}</a>
          {session.role === "admin" && <a class="user-menu-item" href="/admin" role="menuitem">{menuCopy.admin}</a>}
          <div class="user-menu-divider" aria-hidden="true"></div>
          <a class="user-menu-item" href="/settings" role="menuitem">{menuCopy.settings}</a>
          <form method="post" action="/api/logout?redirect=/">
            <button class="user-menu-item danger" type="submit" role="menuitem">{menuCopy.logout}</button>
          </form>
        </div>
      </div>
    ) : (
      <a class="login-compact-button" href={loginHref}>
        <span class="login-icon" aria-hidden="true"></span>
        <span>{t(lang, "header.login")}</span>
      </a>
    )}
  </div>
</header>

<script is:inline>
  (() => {
    const storageKey = "whyisee_sidebar_collapsed";
    const button = document.querySelector(".sidebar-toggle");

    if (!button) {
      return;
    }

    const applyState = (collapsed) => {
      document.documentElement.dataset.sidebar = collapsed ? "collapsed" : "";
      if (!collapsed) {
        document.documentElement.removeAttribute("data-sidebar");
      }

      const label = collapsed ? button.dataset.expandLabel : button.dataset.collapseLabel;
      button.setAttribute("aria-expanded", String(!collapsed));
      button.setAttribute("aria-label", label || "");
      button.setAttribute("title", label || "");
    };

    let collapsed = false;
    let animationTimer = 0;

    try {
      collapsed = localStorage.getItem(storageKey) === "1";
    } catch {
      collapsed = false;
    }

    applyState(collapsed);

    button.addEventListener("click", () => {
      window.clearTimeout(animationTimer);
      document.documentElement.dataset.sidebarAnimating = "true";
      collapsed = document.documentElement.dataset.sidebar !== "collapsed";
      applyState(collapsed);

      try {
        localStorage.setItem(storageKey, collapsed ? "1" : "0");
      } catch {
        // Ignore storage failures; the current page can still toggle normally.
      }

      animationTimer = window.setTimeout(() => {
        document.documentElement.removeAttribute("data-sidebar-animating");
      }, 380);
    });
  })();

  (() => {
    const form = document.querySelector("[data-header-search]");
    const button = document.querySelector("[data-search-toggle]");
    const input = document.querySelector("[data-search-input]");
    const panel = document.querySelector("[data-search-panel]");
    const aiButton = document.querySelector("[data-header-ai-search]");
    const plan = document.querySelector("[data-header-search-plan]");
    const state = document.querySelector("[data-search-state]");
    const results = document.querySelector("[data-search-results]");
    const examples = document.querySelectorAll("[data-header-search-example]");

    if (!form || !button || !input || !panel || !aiButton || !plan || !state || !results) {
      return;
    }

    const labels = {
      loading: form.dataset.searchLoading || "Searching...",
      aiLoading: form.dataset.searchAiLoading || "AI is searching...",
      aiSearching: form.dataset.searchAiSearching || "Searching with AI directives...",
      empty: form.dataset.searchEmpty || "No matching results.",
      error: form.dataset.searchError || "Search failed.",
      hint: form.dataset.searchHint || "",
      translated: form.dataset.searchTranslated || "AI translated",
      plan: form.dataset.searchPlan || "Search",
      usedDirective: form.dataset.searchUsedDirective || "Using",
    };
    const kindLabels = form.dataset.searchLang === "en"
      ? {
          topic: "Topic",
          reply: "Reply",
          category: "Category",
          tag: "Tag",
          user: "User",
        }
      : {
          topic: "话题",
          reply: "回复",
          category: "分类",
          tag: "标签",
          user: "用户",
        };
    const searchDelay = 280;
    let searchTimer = 0;
    let lastQuery = "";
    let lastMode = "directive";
    let activeController = null;
    let resultItems = [];
    let activeIndex = -1;

    const setOpen = (open, focusInput = true) => {
      form.classList.toggle("is-open", open);
      button.setAttribute("aria-expanded", String(open));
      input.tabIndex = open ? 0 : -1;

      if (!open) {
        panel.hidden = true;
        form.classList.remove("has-results");
      }

      if (open && focusInput) {
        requestAnimationFrame(() => input.focus());
        if (!input.value.trim()) {
          showHelp();
        }
      }
    };

    const setPanelOpen = (open) => {
      panel.hidden = !open;
      form.classList.toggle("has-results", open);
    };

    const setActive = (index) => {
      resultItems.forEach((item, itemIndex) => {
        item.classList.toggle("is-active", itemIndex === index);
      });
      activeIndex = index;
    };

    const clearResults = () => {
      results.replaceChildren();
      resultItems = [];
      activeIndex = -1;
    };

    const clearPlan = () => {
      plan.hidden = true;
      delete plan.dataset.source;
      plan.replaceChildren();
    };

    const showState = (message) => {
      clearResults();
      state.hidden = false;
      state.textContent = message;
      setPanelOpen(true);
    };

    const showHelp = () => {
      clearResults();
      clearPlan();
      state.hidden = false;
      state.textContent = labels.hint;
      setPanelOpen(true);
    };

    const hidePanel = () => {
      setPanelOpen(false);
      setActive(-1);
    };

    const renderPlan = (data, mode) => {
      clearPlan();

      const normalizedQuery = data?.ai?.directiveQuery || data?.plan?.normalizedQuery || "";
      const notes = Array.isArray(data?.plan?.notes) ? data.plan.notes : [];
      const warnings = Array.isArray(data?.plan?.warnings) ? data.plan.warnings : [];

      if (!normalizedQuery && !notes.length && !warnings.length) {
        return;
      }

      const title = document.createElement("strong");
      title.textContent = mode === "ai" && data?.ai ? labels.translated : labels.plan;
      plan.append(title);

      if (normalizedQuery) {
        const code = document.createElement("code");
        code.textContent = normalizedQuery;
        plan.append(code);
      }

      [...notes, ...warnings].slice(0, 2).forEach((item) => {
        const note = document.createElement("span");
        note.textContent = item;
        plan.append(note);
      });

      plan.hidden = false;
    };

    const renderAiDirective = (translation) => {
      clearPlan();

      const directiveQuery = translation?.directiveQuery || translation?.plan?.normalizedQuery || "";

      if (!directiveQuery) {
        return "";
      }

      plan.dataset.source = "ai";

      const title = document.createElement("strong");
      title.textContent = labels.translated;

      const code = document.createElement("code");
      code.textContent = directiveQuery;

      const note = document.createElement("span");
      note.textContent = labels.usedDirective;

      plan.append(title, note, code);
      plan.hidden = false;

      return directiveQuery;
    };

    const renderResult = (item) => {
      const row = document.createElement("a");
      row.className = "header-search-result";
      row.href = item.href;

      const head = document.createElement("span");
      head.className = "header-search-result-head";

      const badge = document.createElement("span");
      badge.className = "header-search-kind";
      badge.textContent = kindLabels[item.kind] || item.kind || "";

      const title = document.createElement("strong");
      title.textContent = item.title || "";

      head.append(badge, title);
      row.append(head);

      if (item.summary) {
        const summary = document.createElement("span");
        summary.className = "header-search-summary";
        summary.textContent = item.summary;
        row.append(summary);
      }

      if (item.meta) {
        const meta = document.createElement("small");
        meta.textContent = item.meta;
        row.append(meta);
      }

      return row;
    };

    const renderResults = (items) => {
      clearResults();

      if (!items.length) {
        showState(labels.empty);
        return;
      }

      state.hidden = true;
      items.forEach((item) => results.append(renderResult(item)));
      resultItems = Array.from(results.querySelectorAll(".header-search-result"));
      setPanelOpen(true);
    };

    const runSearch = async (mode = "directive") => {
      const query = input.value.trim();

      if (!query) {
        lastQuery = "";
        lastMode = mode;
        clearResults();
        showHelp();
        return;
      }

      if (query === lastQuery && mode === lastMode && resultItems.length) {
        setPanelOpen(true);
        return;
      }

      lastQuery = query;
      lastMode = mode;
      clearPlan();
      showState(mode === "ai" ? labels.aiLoading : labels.loading);

      if (activeController) {
        activeController.abort();
      }

      activeController = new AbortController();

      try {
        const url = new URL("/api/search", window.location.origin);
        url.searchParams.set("q", query);
        url.searchParams.set("limit", "8");
        url.searchParams.set("lang", form.dataset.searchLang || "zh");
        url.searchParams.set("mode", mode);

        const response = await fetch(url, {
          headers: { accept: "application/json" },
          signal: activeController.signal,
        });

        if (!response.ok) {
          throw new Error(`Search failed: ${response.status}`);
        }

        const data = await response.json();

        if (input.value.trim() !== query) {
          return;
        }

        renderPlan(data, mode);
        renderResults(Array.isArray(data.results) ? data.results : []);
      } catch (error) {
        if (error?.name === "AbortError") {
          return;
        }

        showState(labels.error);
      }
    };

    const runAiSearch = async () => {
      const originalQuery = input.value.trim();

      if (!originalQuery) {
        input.focus();
        showHelp();
        return;
      }

      window.clearTimeout(searchTimer);
      lastQuery = originalQuery;
      lastMode = "ai";
      clearPlan();
      showState(labels.aiLoading);

      if (activeController) {
        activeController.abort();
      }

      activeController = new AbortController();

      try {
        const translateResponse = await fetch("/api/search/translate", {
          method: "POST",
          headers: {
            accept: "application/json",
            "content-type": "application/json",
          },
          body: JSON.stringify({ q: originalQuery }),
          signal: activeController.signal,
        });

        if (!translateResponse.ok) {
          throw new Error(`AI translate failed: ${translateResponse.status}`);
        }

        const translation = await translateResponse.json();

        if (input.value.trim() !== originalQuery) {
          return;
        }

        const directiveQuery = renderAiDirective(translation);
        showState(labels.aiSearching);

        const url = new URL("/api/search", window.location.origin);
        url.searchParams.set("q", directiveQuery || originalQuery);
        url.searchParams.set("limit", "8");
        url.searchParams.set("lang", form.dataset.searchLang || "zh");
        url.searchParams.set("mode", "directive");

        const searchResponse = await fetch(url, {
          headers: { accept: "application/json" },
          signal: activeController.signal,
        });

        if (!searchResponse.ok) {
          throw new Error(`Search failed: ${searchResponse.status}`);
        }

        const data = await searchResponse.json();

        if (input.value.trim() !== originalQuery) {
          return;
        }

        renderResults(Array.isArray(data.results) ? data.results : []);
      } catch (error) {
        if (error?.name === "AbortError") {
          return;
        }

        clearPlan();
        showState(labels.error);
      }
    };

    const scheduleSearch = () => {
      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(runSearch, searchDelay);
    };

    button.addEventListener("click", () => {
      const isOpen = form.classList.contains("is-open");

      if (!isOpen) {
        setOpen(true);
        return;
      }

      if (input.value.trim()) {
        runSearch();
        return;
      }

      setOpen(false);
    });

    input.addEventListener("input", () => {
      setOpen(true);
      clearPlan();
      scheduleSearch();
    });

    input.addEventListener("focus", () => {
      if (input.value.trim()) {
        runSearch();
      } else {
        showHelp();
      }
    });

    aiButton.addEventListener("click", () => {
      if (!input.value.trim()) {
        input.focus();
        showHelp();
        return;
      }

      setOpen(true, false);
      runAiSearch();
    });

    examples.forEach((example) => {
      example.addEventListener("click", () => {
        input.value = example.dataset.headerSearchExample || "";
        lastQuery = "";
        window.clearTimeout(searchTimer);
        setOpen(true);
        runSearch("directive");
      });
    });

    input.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        window.clearTimeout(searchTimer);
        hidePanel();

        if (!input.value.trim()) {
          setOpen(false);
          button.focus();
        }
      }

      if (event.key === "ArrowDown" && resultItems.length) {
        event.preventDefault();
        setActive((activeIndex + 1) % resultItems.length);
      }

      if (event.key === "ArrowUp" && resultItems.length) {
        event.preventDefault();
        setActive(activeIndex <= 0 ? resultItems.length - 1 : activeIndex - 1);
      }

      if (event.key === "Enter" && resultItems.length) {
        event.preventDefault();
        resultItems[Math.max(activeIndex, 0)]?.click();
      }
    });

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      if (resultItems.length) {
        resultItems[Math.max(activeIndex, 0)]?.click();
        return;
      }

      runSearch("directive");
    });

    document.addEventListener("click", (event) => {
      if (!form.contains(event.target)) {
        hidePanel();

        if (!input.value.trim()) {
          setOpen(false);
        }
      }
    });
  })();

  (() => {
    const switcher = document.querySelector("[data-language-switch]");
    const button = document.querySelector("[data-language-button]");
    const menu = document.querySelector("[data-language-menu]");
    const input = document.querySelector("[data-language-input]");

    if (!switcher || !button || !menu || !input) {
      return;
    }

    const setOpen = (open) => {
      menu.hidden = !open;
      button.setAttribute("aria-expanded", String(open));
      switcher.dataset.open = open ? "true" : "false";
    };

    button.addEventListener("click", () => {
      setOpen(menu.hidden);
    });

    menu.querySelectorAll("[data-lang-value]").forEach((option) => {
      option.addEventListener("click", () => {
        input.value = option.dataset.langValue || input.value;
      });
    });

    document.addEventListener("click", (event) => {
      if (!switcher.contains(event.target)) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setOpen(false);
        button.focus();
      }
    });
  })();

  (() => {
    const menu = document.querySelector("[data-user-menu]");
    const button = document.querySelector("[data-user-menu-button]");
    const panel = document.querySelector("[data-user-menu-panel]");

    if (!menu || !button || !panel) {
      return;
    }

    const setOpen = (open) => {
      panel.hidden = !open;
      button.setAttribute("aria-expanded", String(open));
      menu.dataset.open = open ? "true" : "false";
    };

    button.addEventListener("click", () => {
      setOpen(panel.hidden);
    });

    document.addEventListener("click", (event) => {
      if (!menu.contains(event.target)) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setOpen(false);
        button.focus();
      }
    });
  })();
</script>
