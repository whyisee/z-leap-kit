---
import type { Category, Tag, Topic, TopicStatus, TopicType } from "@lib/types";
import type { Lang } from "@lib/i18n";
import MarkdownImageUpload from "@components/MarkdownImageUpload.astro";
import MentionAutocomplete from "@components/MentionAutocomplete.astro";

interface Props {
  action: string;
  categories: Category[];
  tags: Tag[];
  lang: Lang;
  topic?: Topic;
  submitLabel?: string;
  cancelHref?: string;
  error?: boolean;
  showAdminFields?: boolean;
  forcedStatus?: TopicStatus;
  defaultCategorySlug?: string;
  defaultTagSlugs?: string[];
  defaultType?: TopicType;
}

const {
  action,
  categories,
  tags,
  lang,
  topic,
  submitLabel,
  cancelHref = "/admin",
  error = false,
  showAdminFields = true,
  forcedStatus,
  defaultCategorySlug,
  defaultTagSlugs = [],
  defaultType,
} = Astro.props;
const copy = getCopy(lang);
const selectedType = topic?.type || defaultType || "discussion";
const selectedStatus = forcedStatus || topic?.status || "draft";
const defaultCategory = categories.find((category) => category.slug === defaultCategorySlug);
const selectedCategoryId = topic?.category.id || defaultCategory?.id || categories[0]?.id;
const defaultTagNames = defaultTagSlugs
  .map((slug) => tags.find((tag) => tag.slug === slug)?.name)
  .filter(Boolean);
const tagValue = topic?.tags.map((tag) => tag.name).join(", ") || defaultTagNames.join(", ");
const selectedTagNames = normalizeTagValue(tagValue);
const selectedTagNameSet = new Set(selectedTagNames.map((name) => name.toLowerCase()));
const isPublicTopicForm = !showAdminFields;

const typeOptions: Array<{ value: TopicType; label: string }> = [
  { value: "discussion", label: copy.typeDiscussion },
  { value: "question", label: copy.typeQuestion },
  { value: "article", label: copy.typeArticle },
  { value: "project", label: copy.typeProject },
  { value: "resource", label: copy.typeResource },
  { value: "announcement", label: copy.typeAnnouncement },
];

const writingStyleOptions = [
  { value: "community", label: copy.aiStyleCommunity },
  { value: "technical", label: copy.aiStyleTechnical },
  { value: "story", label: copy.aiStyleStory },
  { value: "tutorial", label: copy.aiStyleTutorial },
  { value: "opinion", label: copy.aiStyleOpinion },
  { value: "launch", label: copy.aiStyleLaunch },
  { value: "casual", label: copy.aiStyleCasual },
];

const statusOptions: Array<{ value: TopicStatus; label: string }> = [
  { value: "draft", label: copy.statusDraft },
  { value: "pending", label: copy.statusPending },
  { value: "published", label: copy.statusPublished },
  { value: "hidden", label: copy.statusHidden },
];

function getCopy(lang: Lang) {
  if (lang === "en") {
    return {
      title: "Title",
      titlePlaceholder: "A specific question, case study, or project update",
      slug: "Slug",
      slugPlaceholder: "auto-generated if empty",
      slugHelp: "Used in the public URL. Leave empty to generate from title.",
      summary: "Summary",
      summaryPlaceholder: "A short description for topic lists and SEO.",
      summaryHelp: "Optional. Leave it empty and the system will derive one from the body.",
      optional: "Optional",
      settings: "Publish settings",
      category: "Category",
      type: "Type",
      status: "Status",
      tags: "Tags",
      tagsPlaceholder: "cursor, indie-dev, feedback",
      tagsHelp: "Select multiple tags, or type a custom tag and press Enter.",
      body: "Body",
      bodyPlaceholder: "Write the body here. Markdown and image upload are supported.",
      pinned: "Pinned",
      featured: "Featured",
      save: "Save Topic",
      cancel: "Cancel",
      error: "Failed to save. Check title, body, category, and database connection.",
      statusDraft: "Draft",
      statusPending: "Pending",
      statusPublished: "Published",
      statusHidden: "Hidden",
      typeDiscussion: "Discussion",
      typeQuestion: "Question",
      typeArticle: "Article",
      typeProject: "Project",
      typeResource: "Resource",
      typeAnnouncement: "Announcement",
      aiWriting: "AI writing",
      aiStyle: "Writing style",
      aiStyleCommunity: "Community",
      aiStyleTechnical: "Technical",
      aiStyleStory: "Story",
      aiStyleTutorial: "Tutorial",
      aiStyleOpinion: "Opinion",
      aiStyleLaunch: "Launch",
      aiStyleCasual: "Casual",
      aiDraft: "Write full body",
      aiOutline: "Generate outline",
      aiContinue: "Continue body",
      aiTitle: "Generate titles",
      aiPolish: "Polish content",
      aiHumanize: "Remove AI tone",
      aiSummary: "Generate summary",
      aiRecommend: "Recommend settings",
      aiLoading: "AI is writing...",
      aiEmpty: "Add a title or body before using AI.",
      aiError: "AI request failed. Please try again later.",
      aiLoginRequired: "Please log in before using AI tools.",
      aiNotConfigured: "AI model is not configured yet.",
      aiKeyMissing: "The default AI model is missing an API key.",
      aiTimeout: "AI request timed out. Try again with a shorter draft.",
      aiApplyTitle: "Use title",
      aiApplySummary: "Use summary",
      aiReplaceBody: "Replace body",
      aiAppendBody: "Append to body",
      aiApplyMeta: "Apply settings",
      aiCopy: "Copy",
      aiCopied: "Copied",
      aiClose: "Close",
    };
  }

  return {
    title: "标题",
    titlePlaceholder: "具体问题、复盘标题或项目更新",
    slug: "URL Slug",
    slugPlaceholder: "留空会根据标题自动生成",
    slugHelp: "用于公开访问 URL。留空自动生成。",
    summary: "摘要",
    summaryPlaceholder: "用于话题列表和 SEO 的简短描述。",
    summaryHelp: "可选。不填时系统会根据正文自动生成一段摘要。",
    optional: "可选",
    settings: "发布设置",
    category: "分类",
    type: "类型",
    status: "状态",
    tags: "标签",
    tagsPlaceholder: "cursor, 独立开发, 求反馈",
    tagsHelp: "可多选标签，也可以输入自定义标签后回车添加。",
    body: "正文",
    bodyPlaceholder: "直接写正文，支持 Markdown 和图片上传。",
    pinned: "置顶",
    featured: "精选",
    save: "保存话题",
    cancel: "取消",
    error: "保存失败。请检查标题、正文、分类和数据库连接。",
    statusDraft: "草稿",
    statusPending: "待审核",
    statusPublished: "发布",
    statusHidden: "隐藏",
    typeDiscussion: "讨论",
    typeQuestion: "问题",
    typeArticle: "文章",
    typeProject: "项目",
    typeResource: "资源",
    typeAnnouncement: "公告",
    aiWriting: "AI 写作",
    aiStyle: "写作风格",
    aiStyleCommunity: "社区自然",
    aiStyleTechnical: "技术解析",
    aiStyleStory: "复盘故事",
    aiStyleTutorial: "教程步骤",
    aiStyleOpinion: "观点评论",
    aiStyleLaunch: "项目更新",
    aiStyleCasual: "轻松口语",
    aiDraft: "生成正文",
    aiOutline: "生成大纲",
    aiContinue: "续写正文",
    aiTitle: "生成标题",
    aiPolish: "润色内容",
    aiHumanize: "去 AI 味",
    aiSummary: "生成摘要",
    aiRecommend: "推荐分类标签",
    aiLoading: "AI 正在写...",
    aiEmpty: "先写一点标题或正文，再使用 AI。",
    aiError: "AI 请求失败，请稍后再试。",
    aiLoginRequired: "请先登录后再使用 AI 工具。",
    aiNotConfigured: "还没有配置 AI 模型。",
    aiKeyMissing: "默认 AI 模型缺少 API Key。",
    aiTimeout: "AI 请求超时，可以换一个较短的草稿再试。",
    aiApplyTitle: "使用标题",
    aiApplySummary: "使用摘要",
    aiReplaceBody: "替换正文",
    aiAppendBody: "追加到正文",
    aiApplyMeta: "应用设置",
    aiCopy: "复制",
    aiCopied: "已复制",
    aiClose: "关闭",
  };
}

function normalizeTagValue(value: string) {
  const seen = new Set<string>();
  const names: string[] = [];

  for (const item of value.split(/[,，\n]/)) {
    const name = item.trim();
    const key = name.toLowerCase();

    if (!name || seen.has(key)) {
      continue;
    }

    seen.add(key);
    names.push(name);
  }

  return names;
}
---

{error && <p class="auth-message error">{copy.error}</p>}

<form class:list={["draft-form", "admin-topic-form", isPublicTopicForm && "public-topic-form"]} method="post" action={action} data-topic-form>
  {showAdminFields ? (
    <>
      <div class="form-grid two">
        <label>
          {copy.title}
          <input name="title" type="text" value={topic?.title || ""} placeholder={copy.titlePlaceholder} required />
        </label>
        <label>
          {copy.slug}
          <input name="slug" type="text" value={topic?.slug || ""} placeholder={copy.slugPlaceholder} />
          <small>{copy.slugHelp}</small>
        </label>
      </div>

      <label>
        {copy.summary}
        <textarea name="summary" rows="3" placeholder={copy.summaryPlaceholder}>{topic?.summary || ""}</textarea>
      </label>

      <div class="form-grid three">
        <label>
          {copy.category}
          <select name="categoryId" required>
            {categories.map((category) => (
              <option value={category.id} selected={category.id === selectedCategoryId}>{category.name}</option>
            ))}
          </select>
        </label>
        <label>
          {copy.type}
          <select name="type">
            {typeOptions.map((option) => (
              <option value={option.value} selected={option.value === selectedType}>{option.label}</option>
            ))}
          </select>
        </label>
        <label>
          {copy.status}
          <select name="status">
            {statusOptions.map((option) => (
              <option value={option.value} selected={option.value === selectedStatus}>{option.label}</option>
            ))}
          </select>
        </label>
      </div>

      <div class="form-field tag-picker-field" data-tag-picker>
        <span class="form-label">{copy.tags}</span>
        <input name="tags" type="hidden" value={tagValue} data-tag-picker-value />
        <div class="tag-picker-selected" data-tag-picker-selected hidden></div>
        <div class="tag-picker-list" aria-label={copy.tags}>
          {tags.map((tag) => (
            <button
              class:list={["tag-picker-chip", selectedTagNameSet.has(tag.name.toLowerCase()) && "is-selected"]}
              type="button"
              aria-pressed={selectedTagNameSet.has(tag.name.toLowerCase()) ? "true" : "false"}
              data-tag-picker-chip
              data-tag-name={tag.name}
            >
              #{tag.name}
            </button>
          ))}
        </div>
        <input class="tag-picker-custom" type="text" placeholder={copy.tagsPlaceholder} data-tag-picker-custom />
        <small>{copy.tagsHelp}</small>
      </div>

      <label>
        {copy.body}
        <textarea name="contentMarkdown" rows="16" placeholder={copy.bodyPlaceholder} required>{topic?.contentMarkdown || ""}</textarea>
        <MarkdownImageUpload lang={lang} />
      </label>

      <div class="form-switches">
        <label class="checkbox-label">
          <input name="isPinned" type="checkbox" value="1" checked={topic?.isPinned || false} />
          {copy.pinned}
        </label>
        <label class="checkbox-label">
          <input name="isFeatured" type="checkbox" value="1" checked={topic?.isFeatured || false} />
          {copy.featured}
        </label>
      </div>

      <div class="form-actions">
        <button class="button primary" type="submit">{submitLabel || copy.save}</button>
        <a class="button secondary" href={cancelHref}>{copy.cancel}</a>
      </div>
    </>
  ) : (
    <>
      <div class="public-topic-editor">
        <div
          class="writing-ai-box"
          data-writing-ai
          data-loading={copy.aiLoading}
          data-empty={copy.aiEmpty}
          data-error={copy.aiError}
          data-login-required={copy.aiLoginRequired}
          data-not-configured={copy.aiNotConfigured}
          data-key-missing={copy.aiKeyMissing}
          data-timeout={copy.aiTimeout}
          data-copied={copy.aiCopied}
          data-copy={copy.aiCopy}
        >
          <div class="writing-ai-toolbar">
            <label class="writing-ai-style">
              <span>{copy.aiStyle}</span>
              <select data-writing-ai-style aria-label={copy.aiStyle}>
                {writingStyleOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
            <button
              class="writing-ai-button"
              type="button"
              aria-haspopup="menu"
              aria-expanded="false"
              data-writing-ai-button
            >
              <span class="writing-ai-mark" aria-hidden="true">AI</span>
              <span>{copy.aiWriting}</span>
              <span class="writing-ai-chevron" aria-hidden="true">⌄</span>
            </button>
            <div class="writing-ai-menu" role="menu" data-writing-ai-menu hidden>
              <button type="button" role="menuitem" data-writing-ai-action="draft">{copy.aiDraft}</button>
              <button type="button" role="menuitem" data-writing-ai-action="outline">{copy.aiOutline}</button>
              <button type="button" role="menuitem" data-writing-ai-action="continue">{copy.aiContinue}</button>
              <button type="button" role="menuitem" data-writing-ai-action="polish">{copy.aiPolish}</button>
              <button type="button" role="menuitem" data-writing-ai-action="humanize">{copy.aiHumanize}</button>
              <button type="button" role="menuitem" data-writing-ai-action="title">{copy.aiTitle}</button>
              <button type="button" role="menuitem" data-writing-ai-action="summary">{copy.aiSummary}</button>
              <button type="button" role="menuitem" data-writing-ai-action="recommend">{copy.aiRecommend}</button>
            </div>
          </div>
          <section class="writing-ai-result" data-writing-ai-result hidden>
            <header>
              <h2 data-writing-ai-title>{copy.aiWriting}</h2>
              <button class="action-button compact" type="button" data-writing-ai-close>{copy.aiClose}</button>
            </header>
            <pre data-writing-ai-output></pre>
            <div class="writing-ai-title-list" data-writing-ai-title-list hidden></div>
            <div class="writing-ai-result-actions">
              <button class="action-button compact" type="button" data-writing-ai-apply-summary hidden>{copy.aiApplySummary}</button>
              <button class="action-button compact" type="button" data-writing-ai-replace-body hidden>{copy.aiReplaceBody}</button>
              <button class="action-button compact" type="button" data-writing-ai-append-body hidden>{copy.aiAppendBody}</button>
              <button class="action-button compact" type="button" data-writing-ai-apply-meta hidden>{copy.aiApplyMeta}</button>
              <button class="action-button compact" type="button" data-writing-ai-copy>{copy.aiCopy}</button>
            </div>
          </section>
        </div>

        <label>
          {copy.title}
          <input name="title" type="text" value={topic?.title || ""} placeholder={copy.titlePlaceholder} required />
        </label>

        <label class="topic-body-label">
          {copy.body}
          <textarea name="contentMarkdown" rows="22" placeholder={copy.bodyPlaceholder} required>{topic?.contentMarkdown || ""}</textarea>
          <MarkdownImageUpload lang={lang} />
        </label>
      </div>

      <aside class="public-topic-sidebar" aria-label={copy.settings}>
        <input name="status" type="hidden" value={selectedStatus} />
        <div class="public-topic-panel">
          <p class="public-topic-panel-title">{copy.settings}</p>
          <label>
            {copy.category}
            <select name="categoryId" required>
              {categories.map((category) => (
                <option value={category.id} selected={category.id === selectedCategoryId}>{category.name}</option>
              ))}
            </select>
          </label>
          <label>
            {copy.type}
            <select name="type">
              {typeOptions.map((option) => (
                <option value={option.value} selected={option.value === selectedType}>{option.label}</option>
              ))}
            </select>
          </label>
          <div class="form-field tag-picker-field" data-tag-picker>
            <span class="form-label">{copy.tags}</span>
            <input name="tags" type="hidden" value={tagValue} data-tag-picker-value />
            <div class="tag-picker-selected" data-tag-picker-selected hidden></div>
            <div class="tag-picker-list" aria-label={copy.tags}>
              {tags.map((tag) => (
                <button
                  class:list={["tag-picker-chip", selectedTagNameSet.has(tag.name.toLowerCase()) && "is-selected"]}
                  type="button"
                  aria-pressed={selectedTagNameSet.has(tag.name.toLowerCase()) ? "true" : "false"}
                  data-tag-picker-chip
                  data-tag-name={tag.name}
                >
                  #{tag.name}
                </button>
              ))}
            </div>
            <input class="tag-picker-custom" type="text" placeholder={copy.tagsPlaceholder} data-tag-picker-custom />
            <small>{copy.tagsHelp}</small>
          </div>
          <details class="public-topic-optional">
            <summary>
              <span>{copy.summary}</span>
              <small>{copy.optional}</small>
            </summary>
            <textarea name="summary" rows="3" placeholder={copy.summaryPlaceholder} aria-label={copy.summary}>{topic?.summary || ""}</textarea>
            <small>{copy.summaryHelp}</small>
          </details>
        </div>

        <div class="form-actions public-topic-actions">
          <button class="button primary" type="submit">{submitLabel || copy.save}</button>
          <a class="button secondary" href={cancelHref}>{copy.cancel}</a>
        </div>
      </aside>
    </>
  )}
</form>

<MentionAutocomplete lang={lang} />

<script is:inline>
  (() => {
    const splitTags = (value) => value
      .split(/[,，\n]/)
      .map((item) => item.trim())
      .filter(Boolean);
    const normalize = (value) => value.trim().toLowerCase();

    document.querySelectorAll("[data-tag-picker]").forEach((picker) => {
      const valueInput = picker.querySelector("[data-tag-picker-value]");
      const selectedBox = picker.querySelector("[data-tag-picker-selected]");
      const customInput = picker.querySelector("[data-tag-picker-custom]");
      const chips = Array.from(picker.querySelectorAll("[data-tag-picker-chip]"));

      if (!(valueInput instanceof HTMLInputElement)) {
        return;
      }

      let selected = [];

      const addTag = (value) => {
        const tag = value.trim();

        if (!tag) {
          return;
        }

        const key = normalize(tag);

        if (selected.some((item) => normalize(item) === key)) {
          return;
        }

        selected.push(tag);
      };

      const removeTag = (value) => {
        const key = normalize(value);
        selected = selected.filter((item) => normalize(item) !== key);
      };

      const renderSelected = () => {
        if (!selectedBox) {
          return;
        }

        selectedBox.replaceChildren();
        selectedBox.hidden = selected.length === 0;

        selected.forEach((tag) => {
          const button = document.createElement("button");
          button.className = "tag-picker-selected-chip";
          button.type = "button";
          button.textContent = `#${tag} ×`;
          button.addEventListener("click", () => {
            removeTag(tag);
            sync();
          });
          selectedBox.append(button);
        });
      };

      const sync = () => {
        const selectedKeys = new Set(selected.map(normalize));
        valueInput.value = selected.join(", ");

        chips.forEach((chip) => {
          const active = selectedKeys.has(normalize(chip.dataset.tagName || ""));
          chip.classList.toggle("is-selected", active);
          chip.setAttribute("aria-pressed", String(active));
        });

        renderSelected();
      };

      selected = [];
      splitTags(valueInput.value).forEach(addTag);
      sync();

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const tag = chip.dataset.tagName || "";
          const active = selected.some((item) => normalize(item) === normalize(tag));

          if (active) {
            removeTag(tag);
          } else {
            addTag(tag);
          }

          sync();
        });
      });

      if (customInput instanceof HTMLInputElement) {
        const commitCustom = () => {
          splitTags(customInput.value).forEach(addTag);
          customInput.value = "";
          sync();
        };

        customInput.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === "," || event.key === "，") {
            event.preventDefault();
            commitCustom();
          }
        });

        customInput.addEventListener("blur", commitCustom);
      }

      picker.addEventListener("whyisee:set-tags", (event) => {
        selected = [];
        const tags = Array.isArray(event.detail?.tags) ? event.detail.tags : [];
        tags.forEach(addTag);
        sync();
      });
    });
  })();

  (() => {
    const root = document.querySelector("[data-writing-ai]");

    if (!root) {
      return;
    }

    const form = root.closest("[data-topic-form]");
    const button = root.querySelector("[data-writing-ai-button]");
    const menu = root.querySelector("[data-writing-ai-menu]");
    const result = root.querySelector("[data-writing-ai-result]");
    const resultTitle = root.querySelector("[data-writing-ai-title]");
    const output = root.querySelector("[data-writing-ai-output]");
    const titleList = root.querySelector("[data-writing-ai-title-list]");
    const closeButton = root.querySelector("[data-writing-ai-close]");
    const copyButton = root.querySelector("[data-writing-ai-copy]");
    const styleSelect = root.querySelector("[data-writing-ai-style]");
    const applySummaryButton = root.querySelector("[data-writing-ai-apply-summary]");
    const replaceBodyButton = root.querySelector("[data-writing-ai-replace-body]");
    const appendBodyButton = root.querySelector("[data-writing-ai-append-body]");
    const applyMetaButton = root.querySelector("[data-writing-ai-apply-meta]");

    if (!form || !button || !menu || !result || !resultTitle || !output || !titleList || !closeButton || !copyButton) {
      return;
    }

    const titleInput = form.querySelector("input[name='title']");
    const bodyInput = form.querySelector("textarea[name='contentMarkdown']");
    const summaryInput = form.querySelector("textarea[name='summary']");
    const categorySelect = form.querySelector("select[name='categoryId']");
    const typeSelect = form.querySelector("select[name='type']");
    const tagsInput = form.querySelector("input[name='tags']");
    const tagPicker = form.querySelector("[data-tag-picker]");
    const actions = Array.from(menu.querySelectorAll("[data-writing-ai-action]"));
    let activeController;
    let latestData = {};

    const setMenuOpen = (open) => {
      menu.hidden = !open;
      button.setAttribute("aria-expanded", String(open));
      root.dataset.open = open ? "true" : "false";
    };

    const readDraft = () => ({
      title: titleInput?.value || "",
      contentMarkdown: bodyInput?.value || "",
      summary: summaryInput?.value || "",
      categoryId: Number(categorySelect?.value || 0),
      type: typeSelect?.value || "discussion",
      tags: tagsInput?.value || "",
      style: styleSelect?.value || "community",
    });

    const setActionsDisabled = (disabled) => {
      actions.forEach((item) => {
        item.disabled = disabled;
      });
    };

    const showResult = (title, state, text) => {
      result.hidden = false;
      result.dataset.state = state;
      resultTitle.textContent = title;
      output.textContent = text;
      titleList.hidden = true;
      titleList.replaceChildren();
      [applySummaryButton, replaceBodyButton, appendBodyButton, applyMetaButton].forEach((item) => {
        if (item) item.hidden = true;
      });
      result.scrollIntoView({ block: "nearest", behavior: "smooth" });
    };

    const showError = (title, code) => {
      const message = errorMessage(code);
      showResult(title, "error", message);
    };

    const showLoading = (title) => {
      showResult(title, "loading", root.dataset.loading || "AI is writing...");
      setActionsDisabled(true);
    };

    const renderResult = (title, data) => {
      latestData = data || {};
      showResult(title, "ready", data.outputMarkdown || "");

      if (Array.isArray(data.titles) && data.titles.length) {
        titleList.hidden = false;
        data.titles.forEach((item) => {
          const option = document.createElement("button");
          option.className = "writing-ai-title-option";
          option.type = "button";
          option.textContent = item;
          option.addEventListener("click", () => {
            if (titleInput) {
              titleInput.value = item;
              titleInput.focus();
            }
          });
          titleList.append(option);
        });
      }

      if (data.summary && applySummaryButton) {
        applySummaryButton.hidden = false;
      }

      if (data.body && replaceBodyButton && appendBodyButton) {
        replaceBodyButton.hidden = false;
        appendBodyButton.hidden = false;
      }

      if ((data.categoryId || data.type || Array.isArray(data.tags)) && applyMetaButton) {
        applyMetaButton.hidden = false;
      }
    };

    const runAction = async (action, title) => {
      const draft = readDraft();

      if (!draft.title.trim() && !draft.contentMarkdown.trim()) {
        showResult(title, "error", root.dataset.empty || "Add a title or body before using AI.");
        return;
      }

      activeController?.abort();
      activeController = new AbortController();
      showLoading(title);

      try {
        const response = await fetch("/api/ai/writing", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ action, ...draft }),
          signal: activeController.signal,
        });
        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          showError(title, data.error);
          return;
        }

        renderResult(title, data);
      } catch (error) {
        if (error?.name !== "AbortError") {
          showError(title, "ai_failed");
        }
      } finally {
        setActionsDisabled(false);
      }
    };

    button.addEventListener("click", (event) => {
      event.stopPropagation();
      setMenuOpen(menu.hidden);
    });

    actions.forEach((actionButton) => {
      actionButton.addEventListener("click", () => {
        setMenuOpen(false);
        runAction(actionButton.dataset.writingAiAction || "", actionButton.textContent?.trim() || "AI");
      });
    });

    closeButton.addEventListener("click", () => {
      result.hidden = true;
    });

    copyButton.addEventListener("click", async () => {
      const text = output.textContent || "";

      if (!text) {
        return;
      }

      try {
        await navigator.clipboard.writeText(text);
        copyButton.textContent = root.dataset.copied || "Copied";
        window.setTimeout(() => {
          copyButton.textContent = root.dataset.copy || "Copy";
        }, 1400);
      } catch {
        copyButton.textContent = root.dataset.copy || "Copy";
      }
    });

    applySummaryButton?.addEventListener("click", () => {
      if (summaryInput && latestData.summary) {
        summaryInput.value = latestData.summary;
        const details = summaryInput.closest("details");
        if (details) details.open = true;
        summaryInput.focus();
      }
    });

    replaceBodyButton?.addEventListener("click", () => {
      if (bodyInput && latestData.body) {
        bodyInput.value = latestData.body;
        bodyInput.focus();
      }
    });

    appendBodyButton?.addEventListener("click", () => {
      if (bodyInput && latestData.body) {
        bodyInput.value = `${bodyInput.value.trim()}\n\n${latestData.body}`.trim();
        bodyInput.focus();
      }
    });

    applyMetaButton?.addEventListener("click", () => {
      if (categorySelect && latestData.categoryId) {
        categorySelect.value = String(latestData.categoryId);
      }

      if (typeSelect && latestData.type) {
        typeSelect.value = latestData.type;
      }

      if (tagPicker && Array.isArray(latestData.tags)) {
        tagPicker.dispatchEvent(new CustomEvent("whyisee:set-tags", {
          detail: { tags: latestData.tags },
        }));
      }
    });

    document.addEventListener("click", (event) => {
      if (event.target instanceof Node && !root.contains(event.target)) {
        setMenuOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setMenuOpen(false);
      }
    });

    function errorMessage(code) {
      if (code === "login_required") return root.dataset.loginRequired || "";
      if (code === "ai_not_configured") return root.dataset.notConfigured || "";
      if (code === "ai_key_missing") return root.dataset.keyMissing || "";
      if (code === "ai_timeout") return root.dataset.timeout || "";
      if (code === "empty_draft") return root.dataset.empty || "";
      return root.dataset.error || "";
    }
  })();
</script>
