---
import SiteHeader from "@components/SiteHeader.astro";
import SiteFooter from "@components/SiteFooter.astro";
import { getLangFromAstro, t } from "@lib/i18n";
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string | null;
  image?: string;
  noCanonical?: boolean;
  ogType?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title: providedTitle,
  description: providedDescription,
  canonicalUrl: providedCanonicalUrl,
  image: providedImage,
  noCanonical = false,
  ogType = "website",
  robots,
  structuredData,
} = Astro.props;

const lang = getLangFromAstro(Astro);
const title = providedTitle || t(lang, "site.title");
const description = providedDescription || t(lang, "site.description");
const siteBase = new URL(Astro.site?.toString() || process.env.SITE_URL || "https://whyisee.xyz");
const canonical = noCanonical
  ? undefined
  : toAbsoluteUrl(providedCanonicalUrl ?? localizedPath(Astro.url.pathname, lang === "en" ? "en" : "zh-CN"));
const pageUrl = canonical || toAbsoluteUrl(`${Astro.url.pathname}${Astro.url.search}`);
const defaultImage = toAbsoluteUrl("/og-image.png");
const image = toAbsoluteUrl(providedImage || "/og-image.png");
const alternateZh = toAbsoluteUrl(localizedPath(Astro.url.pathname, "zh-CN"));
const alternateEn = toAbsoluteUrl(localizedPath(Astro.url.pathname, "en"));
const jsonLd = buildJsonLd();

function toAbsoluteUrl(value: string) {
  return new URL(value, siteBase).toString();
}

function localizedPath(pathname: string, targetLang: "zh-CN" | "en") {
  const url = new URL(pathname || "/", siteBase);

  if (targetLang === "en") {
    url.searchParams.set("lang", "en");
  }

  return `${url.pathname}${url.search}`;
}

function safeJsonLd(value: unknown) {
  return JSON.stringify(value).replace(/</g, "\\u003c");
}

function buildJsonLd() {
  const items = [
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "whyisee.xyz",
      url: toAbsoluteUrl("/"),
      inLanguage: lang === "en" ? "en" : "zh-CN",
      potentialAction: {
        "@type": "SearchAction",
        target: `${toAbsoluteUrl("/search")}?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    },
    canonical && {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "whyisee.xyz",
          item: toAbsoluteUrl("/"),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: title.replace(/\s+-\s+whyisee\.xyz$/i, ""),
          item: canonical,
        },
      ],
    },
    ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : []),
  ].filter(Boolean);

  return items.length ? safeJsonLd(items) : "";
}
---

<!doctype html>
<html lang={lang === "en" ? "en" : "zh-CN"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content="#10151d" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <link rel="preload" href="/icon.png" as="image" type="image/png" />
    {canonical && <link rel="canonical" href={canonical} />}
    {canonical && <link rel="alternate" hreflang="zh-CN" href={alternateZh} />}
    {canonical && <link rel="alternate" hreflang="en" href={alternateEn} />}
    {canonical && <link rel="alternate" hreflang="x-default" href={alternateZh} />}
    <link rel="alternate" type="text/markdown" title="whyisee AI Agent Skill" href="/api/agent/skill.md" />
    <meta name="ai-agent-skill" content="/agent-skill" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="whyisee.xyz" />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "zh_CN"} />
    <meta property="og:image" content={image} />
    <meta property="og:image:secure_url" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content={image === defaultImage ? "summary_large_image" : "summary_large_image"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd}></script>}
    <style is:inline>
      html,
      body {
        height: 100%;
        margin: 0;
      }

      body {
        overflow: hidden;
        background: #0f1118;
        color: #f0f3f7;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        line-height: 1.65;
      }

      .site-shell {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        width: min(1480px, calc(100% - 40px));
        min-width: 1120px;
        height: 100vh;
        margin: 0 auto;
      }

      main {
        min-height: 0;
        overflow: hidden;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 68px;
      }

      main > .plain-page,
      main > .article-page,
      main > .admin-page,
      main > .auth-page {
        height: 100%;
        overflow-y: auto;
        padding: clamp(28px, 4vh, 44px) clamp(56px, 7vw, 112px) 48px;
        scrollbar-gutter: stable;
      }

      main > .article-page {
        width: 100%;
        max-width: none;
      }

      main > .article-page:not(.auth-page),
      main > .admin-page {
        width: min(1180px, 100%);
        margin-right: auto;
        margin-left: auto;
      }

      main > .admin-page:not(.narrow-page) {
        display: grid;
        grid-template-columns: 176px minmax(0, 1fr);
        align-content: start;
        gap: 0 28px;
      }

      main > .admin-page:not(.narrow-page) > :not(.admin-nav) {
        grid-column: 2;
        min-width: 0;
      }

      .admin-nav {
        display: grid;
        grid-row: 1 / span 30;
        grid-column: 1;
        align-self: start;
        gap: 14px;
        border-right: 1px solid rgba(255, 255, 255, 0.085);
        padding: 4px 18px 4px 0;
      }

      main > .article-page.auth-page,
      main > .auth-page {
        display: grid;
        max-width: none;
        place-items: center;
      }

      main > .admin-page.narrow-page {
        width: min(1020px, 100%);
        margin-right: auto;
        margin-left: auto;
      }

      main > .settings-page {
        display: grid;
        align-content: start;
        gap: 28px;
        padding-top: clamp(28px, 5vh, 54px);
      }

      .settings-head {
        display: grid;
        grid-template-columns: 48px minmax(0, 1fr) auto;
        gap: 16px;
        align-items: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.09);
        padding-bottom: 22px;
      }

      .settings-layout {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        gap: 44px;
        align-items: start;
      }

      .settings-sidebar,
      .agent-settings-card {
        display: grid;
      }

      .settings-sidebar {
        gap: 22px;
      }

      .settings-content-panel {
        min-width: 0;
        max-width: 820px;
      }

      .settings-content-head {
        border-bottom: 1px solid rgba(255, 255, 255, 0.09);
        margin-bottom: 22px;
        padding-bottom: 14px;
      }

      .auth-card {
        width: min(460px, 100%);
      }

      .profile-card {
        width: min(720px, 100%);
      }

      @media (max-width: 980px) {
        html,
        body {
          height: auto;
          min-height: 100%;
        }

        body {
          overflow: auto;
        }

        .site-shell {
          width: 100%;
          min-width: 0;
          min-height: 100dvh;
          height: auto;
        }

        main {
          width: 100%;
          min-width: 0;
          overflow: visible;
        }

        .site-header {
          position: sticky;
          top: 0;
          z-index: 80;
          width: 100%;
          min-width: 0;
          min-height: 58px;
          padding: 8px 12px;
        }

        main > .plain-page,
        main > .article-page,
        main > .admin-page,
        main > .auth-page {
          height: auto;
          min-height: 0;
          min-width: 0;
          overflow: visible;
          padding: 22px 14px 36px;
          scrollbar-gutter: auto;
        }

        main > .article-page:not(.auth-page),
        main > .admin-page,
        main > .admin-page.narrow-page {
          width: 100%;
        }

        main > .admin-page:not(.narrow-page) {
          display: block;
        }

        main > .admin-page:not(.narrow-page) > :not(.admin-nav) {
          grid-column: auto;
        }

        .admin-nav {
          display: flex;
          overflow-x: auto;
          grid-row: auto;
          grid-column: auto;
          border-right: 0;
          border-bottom: 1px solid rgba(255, 255, 255, 0.085);
          margin-bottom: 18px;
          padding: 0 0 12px;
          scrollbar-width: none;
        }

        .settings-head,
        .settings-layout {
          grid-template-columns: minmax(0, 1fr);
        }

        .settings-content-panel {
          max-width: none;
        }
      }
    </style>
    <script is:inline>
      try {
        const storedSidebar = localStorage.getItem("whyisee_sidebar_collapsed");
        const isNarrowScreen = window.matchMedia?.("(max-width: 980px)").matches;
        const shouldStartCollapsed = isNarrowScreen || storedSidebar === "1";

        if (shouldStartCollapsed) {
          document.documentElement.dataset.sidebar = "collapsed";
        }
      } catch {
        document.documentElement.removeAttribute("data-sidebar");
      }

      try {
        const readingArrival = JSON.parse(sessionStorage.getItem("whyisee_topic_reading_arrival") || "{}");

        if (
          readingArrival
          && readingArrival.path === window.location.pathname
          && /^\/t\/\d+/.test(readingArrival.path)
          && Date.now() - Number(readingArrival.createdAt || 0) <= 10000
        ) {
          document.documentElement.dataset.readingArriving = "true";
          document.documentElement.dataset.readingMode = "true";
          document.documentElement.dataset.topicTitleStuck = "true";

          if ("scrollRestoration" in window.history) {
            window.history.scrollRestoration = "manual";
          }
        }
      } catch {
        document.documentElement.removeAttribute("data-reading-arriving");
      }
    </script>
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader lang={lang} />
      <main>
        <slot />
      </main>
      <SiteFooter lang={lang} />
    </div>
  </body>
</html>
