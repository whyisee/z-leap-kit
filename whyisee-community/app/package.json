{
  "name": "whyisee-community",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 0.0.0.0",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "start": "node ./dist/server/entry.mjs",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check && tsc --noEmit",
    "migrate": "node --experimental-strip-types scripts/migrate.ts",
    "seed": "node --experimental-strip-types scripts/seed.ts",
    "launch:reset": "node --experimental-strip-types scripts/launch-reset.ts",
    "launch:seed-users": "node --experimental-strip-types scripts/launch-seed-users.ts",
    "launch:seed-content": "node --experimental-strip-types scripts/launch-seed-content.ts",
    "launch:seed-interactions": "node --experimental-strip-types scripts/launch-seed-interactions.ts",
    "db:init": "npm run migrate && npm run seed",
    "backup:db": "node --experimental-strip-types scripts/backup-db.ts",
    "bot:worker": "node --experimental-strip-types scripts/bot-worker.ts"
  },
  "dependencies": {
    "@astrojs/node": "latest",
    "astro": "latest",
    "flatpickr": "^4.6.13",
    "hono": "latest",
    "marked": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "typescript": "latest"
  }
}
