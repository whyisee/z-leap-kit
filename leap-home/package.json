{
  "name": "leap-home",
  "displayName": "Leap Home",
  "description": "Cursor / VS Code 编辑窗口里的个人知识库首页。",
  "version": "0.1.2",
  "publisher": "whyisee",
  "author": "whyisee",
  "license": "MIT",
  "icon": "resources/icon-128.png",
  "homepage": "https://github.com/whyisee/z-leap-kit/tree/main/leap-home",
  "bugs": {
    "url": "https://github.com/whyisee/z-leap-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whyisee/z-leap-kit.git",
    "directory": "leap-home"
  },
  "keywords": [
    "cursor",
    "vscode",
    "knowledge-base",
    "productivity",
    "dashboard",
    "notes",
    "search",
    "ai"
  ],
  "galleryBanner": {
    "color": "#101214",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:leapHome.openHome",
    "onCommand:leapHome.chooseStatusBarComponent",
    "onCommand:leapHome.searchKnowledge",
    "onCommand:leapHome.captureNote",
    "onCommand:leapHome.refreshIndex",
    "onCommand:leapHome.addCurrentFileToFavorites",
    "onCommand:leapHome.copyPrompt",
    "onCommand:leapHome.switchTemplate",
    "onCommand:leapHome.openTemplateDesigner",
    "onCommand:leapHome.editCustomHome",
    "onCommand:leapHome.editCurrentHome",
    "onCommand:leapHome.closeTemplateDesigner",
    "onCommand:leapHome.configureAi",
    "onCommand:leapHome.showLogs"
  ],
  "scripts": {
    "check": "for f in src/*.js; do node --check \"$f\"; done; node scripts/check-webview.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "leapHome.openHome",
        "title": "Leap Home: 打开知识首页"
      },
      {
        "command": "leapHome.chooseStatusBarComponent",
        "title": "Leap Home: 切换状态栏显示组件"
      },
      {
        "command": "leapHome.searchKnowledge",
        "title": "Leap Home: 搜索知识库"
      },
      {
        "command": "leapHome.captureNote",
        "title": "Leap Home: 记录到收集箱"
      },
      {
        "command": "leapHome.refreshIndex",
        "title": "Leap Home: 刷新索引",
        "icon": "$(refresh)"
      },
      {
        "command": "leapHome.addCurrentFileToFavorites",
        "title": "Leap Home: 收藏当前文件"
      },
      {
        "command": "leapHome.copyPrompt",
        "title": "Leap Home: 复制 Prompt"
      },
      {
        "command": "leapHome.switchTemplate",
        "title": "Leap Home: 切换主页"
      },
      {
        "command": "leapHome.openTemplateDesigner",
        "title": "Leap Home: 新建自定义主页"
      },
      {
        "command": "leapHome.editCustomHome",
        "title": "Leap Home: 修改自定义主页"
      },
      {
        "command": "leapHome.editCurrentHome",
        "title": "Leap Home: 编辑当前主页"
      },
      {
        "command": "leapHome.closeTemplateDesigner",
        "title": "Leap Home: 退出主页编辑"
      },
      {
        "command": "leapHome.configureAi",
        "title": "Leap Home: 配置 AI"
      },
      {
        "command": "leapHome.showLogs",
        "title": "Leap Home: 打开调试日志"
      }
    ],
    "configuration": {
      "title": "Leap Home",
      "properties": {
        "leapHome.homeTemplate": {
          "type": "string",
          "default": "project-workbench",
          "enum": [
            "project-workbench",
            "second-brain",
            "prompt-console",
            "daily-start",
            "minimal"
          ],
          "enumDescriptions": [
            "默认工作台：覆盖搜索、做什么、番茄、倒计日、记录、四象限、日历、知识图谱和统计。",
            "第二大脑首页：更适合从知识库入口开始检索、沉淀和整理。",
            "Prompt 控制台：优先展示 Prompt 模板，并保留快速记录、收藏和周计划。",
            "今日启动页：突出快速记录、常用上下文和今日安排。",
            "极简首页：只保留搜索、收藏、统计和月历。"
          ],
          "description": "Leap Home 默认使用的内置首页模板。设计器保存后的工作区模板优先存放在 .leap/state.json。"
        },
        "leapHome.homeLayout": {
          "type": "array",
          "default": [],
          "description": "默认首页网格布局。设计器保存后的工作区布局优先存放在 .leap/state.json。",
          "items": {
            "type": "object",
            "required": [
              "component"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "布局块唯一标识。"
              },
              "component": {
                "type": "string",
                "enum": [
                  "search",
                  "quickCapture",
                  "focusTimer",
                  "countdown",
                  "nextAction",
                  "knowledgeGraph",
                  "favorites",
                  "prompts",
                  "fourQuadrants",
                  "weekCalendar",
                  "monthCalendar",
                  "stats"
                ],
                "description": "组件类型。"
              },
              "title": {
                "type": "string",
                "description": "覆盖组件默认标题。"
              },
              "col": {
                "type": "number",
                "minimum": 1,
                "maximum": 12,
                "description": "网格起始列，范围 1-12。"
              },
              "row": {
                "type": "number",
                "minimum": 1,
                "description": "网格起始行。"
              },
              "colSpan": {
                "type": "number",
                "minimum": 1,
                "maximum": 12,
                "description": "横向占用列数。"
              },
              "rowSpan": {
                "type": "number",
                "minimum": 1,
                "maximum": 12,
                "description": "纵向占用行数。"
              },
              "span": {
                "type": "number",
                "minimum": 1,
                "maximum": 12,
                "description": "兼容字段，等同于 colSpan。"
              },
              "options": {
                "type": "object",
                "description": "组件参数，例如 limit。"
              }
            }
          }
        },
        "leapHome.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否在 Cursor / VS Code 状态栏展示 Leap Home 快捷入口。"
        },
        "leapHome.statusBar.component": {
          "type": "string",
          "default": "focusTimer",
          "enum": [
            "home",
            "focusTimer",
            "countdown",
            "stats"
          ],
          "enumDescriptions": [
            "只展示 Leap Home 首页入口。",
            "展示番茄时钟剩余时间和状态。",
            "展示最近一个未完成倒计日。",
            "展示索引数量和今日专注时长。"
          ],
          "description": "状态栏快捷入口展示的组件摘要。点击状态栏始终打开 Leap Home 首页。"
        },
        "leapHome.sources": {
          "type": "array",
          "default": [],
          "description": "Leap Home 扫描的本地知识源。",
          "items": {
            "type": "object",
            "required": [
              "name",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "知识源展示名称。"
              },
              "path": {
                "type": "string",
                "description": "绝对路径、~/ 路径或相对当前工作区的路径。"
              },
              "type": {
                "type": "string",
                "enum": [
                  "markdown",
                  "obsidian",
                  "prompt",
                  "workspace"
                ],
                "default": "markdown",
                "description": "知识源类型。"
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "是否扫描这个知识源。"
              }
            }
          }
        },
        "leapHome.inboxPath": {
          "type": "string",
          "default": "",
          "description": "收集箱 Markdown 文件路径。留空时使用当前工作区的 .leap/inbox.md。"
        },
        "leapHome.promptDirs": {
          "type": "array",
          "default": [],
          "description": "Prompt 模板目录。",
          "items": {
            "type": "string"
          }
        },
        "leapHome.maxRecentItems": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 50,
          "description": "首页显示的最近访问数量。"
        },
        "leapHome.search.historyLimit": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "maximum": 100,
          "description": "搜索历史保留数量。设置为 0 时不保存搜索历史。"
        },
        "leapHome.focusTimer.trackForegroundApp": {
          "type": "boolean",
          "default": true,
          "description": "番茄时钟是否通过系统能力识别当前前台应用。启用后只记录应用名称，不记录窗口标题。"
        },
        "leapHome.focusTimer.trustedApps": {
          "type": "array",
          "default": [
            "Cursor",
            "Visual Studio Code",
            "Code",
            "Obsidian",
            "Notion",
            "Google Chrome",
            "Chrome",
            "Safari",
            "Microsoft Edge",
            "Arc",
            "Preview",
            "PDF Expert",
            "Skim",
            "Typora",
            "Xcode",
            "Terminal",
            "iTerm2",
            "Warp",
            "WezTerm"
          ],
          "description": "番茄时钟可信专注应用列表。专注中切到这些应用时仍计入专注时长。",
          "items": {
            "type": "string"
          }
        },
        "leapHome.focusTimer.foregroundAppPollIntervalMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "番茄时钟前台应用检测间隔，单位毫秒。"
        },
        "leapHome.autoIndexWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "是否自动索引当前工作区中的知识文件。"
        },
        "leapHome.index.watchWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "工作区文件变化后是否自动刷新 Leap Home 索引。"
        },
        "leapHome.index.includeExtensions": {
          "type": "array",
          "default": [],
          "description": "额外纳入工作区索引的文件扩展名，例如 .log、.prompt.md。默认已经覆盖常见 Markdown、代码、配置和文本文件。",
          "items": {
            "type": "string"
          }
        },
        "leapHome.index.excludeExtensions": {
          "type": "array",
          "default": [],
          "description": "从工作区索引中排除的文件扩展名，例如 .svg、.lock。",
          "items": {
            "type": "string"
          }
        },
        "leapHome.index.excludePatterns": {
          "type": "array",
          "default": [],
          "description": "从索引中排除的路径片段或简单通配模式，例如 /fixtures/、*.generated.ts。",
          "items": {
            "type": "string"
          }
        },
        "leapHome.index.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "minimum": 16,
          "maximum": 10240,
          "description": "单文件索引大小上限，单位 KB。"
        },
        "leapHome.index.contentLimitKb": {
          "type": "number",
          "default": 64,
          "minimum": 4,
          "maximum": 512,
          "description": "每个文件最多读取并参与检索的正文大小，单位 KB。"
        },
        "leapHome.ai.provider": {
          "type": "string",
          "default": "deepseek",
          "enum": [
            "deepseek"
          ],
          "description": "Leap Home 使用的 AI 服务。"
        },
        "leapHome.ai.deepseekApiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API Key。也可以使用环境变量 DEEPSEEK_API_KEY。"
        },
        "leapHome.ai.deepseekBaseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek API Base URL。"
        },
        "leapHome.ai.deepseekModel": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "用于四象限归类、搜索查询理解和做什么推荐优化的 DeepSeek 模型。"
        },
        "leapHome.ai.searchQueryUnderstanding": {
          "type": "boolean",
          "default": false,
          "description": "是否用 DeepSeek 将自然语言搜索请求改写成 Leap Search 查询语法。默认关闭，避免每次搜索都发起网络请求。"
        },
        "leapHome.ai.timeoutMs": {
          "type": "number",
          "default": 12000,
          "minimum": 3000,
          "maximum": 60000,
          "description": "AI 请求超时时间，单位毫秒。"
        }
      }
    }
  }
}
